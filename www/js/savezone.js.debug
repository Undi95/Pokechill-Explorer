// ============ SAVEZONE ============
// Cloud save storage & Community stats

const SAVEZONE_API_URL = 'https://pokechill-explorer.alwaysdata.net/exchange/api.php';

// Show/hide savezone UI elements
function showSavezoneUI(show) {
    const tabBtn = document.getElementById('savezone-tab-btn');
    const floatBtn = document.getElementById('savezone-float-btn');
    
    if (tabBtn) tabBtn.style.display = show ? 'inline-flex' : 'none';
    if (floatBtn) floatBtn.style.display = show ? 'block' : 'none';
}

// Initialize savezone
function initSavezone() {
    const isLoggedIn = !!localStorage.getItem('lastTeamAuthor');
    showSavezoneUI(isLoggedIn);
    
    const welcomeMsg = document.getElementById('savezone-welcome');
    const content = document.getElementById('savezone-content');
    
    if (welcomeMsg && content) {
        if (isLoggedIn) {
            welcomeMsg.style.display = 'none';
            content.style.display = 'block';
            loadSavezoneData();
        } else {
            welcomeMsg.style.display = 'block';
            content.style.display = 'none';
            // Blocage : on ne charge pas les données
        }
    }
}

// Load user's saves and community stats
async function loadSavezoneData() {
    const username = localStorage.getItem('lastTeamAuthor');
    if (!username) return;
    
    try {
        const response = await fetch(`${SAVEZONE_API_URL}?action=savezone_get&username=${encodeURIComponent(username)}`);
        const data = await response.json();
        
        if (data.success) {
            updateSavezoneSlots(data.saves);
            renderSavezonePokedex(data.saves);
        }
        
        loadCommunityStats();
    } catch (err) {
        console.error('[Savezone] Load error:', err);
    }
}

// Update save slots display
function updateSavezoneSlots(saves) {
    const slot1Date = document.getElementById('savezone-slot1-date');
    const slot1Download = document.getElementById('savezone-slot1-download');
    
    if (slot1Date && slot1Download) {
        if (saves && saves.slot1) {
            slot1Date.textContent = saves.slot1.date;
            slot1Download.style.display = 'block';
            slot1Download.onclick = () => downloadSavezoneSave(1);
        } else {
            slot1Date.textContent = t('noSave');
            slot1Download.style.display = 'none';
        }
    }
    
    const slot2Date = document.getElementById('savezone-slot2-date');
    const slot2Download = document.getElementById('savezone-slot2-download');
    
    if (slot2Date && slot2Download) {
        if (saves && saves.slot2) {
            slot2Date.textContent = saves.slot2.date;
            slot2Download.style.display = 'block';
            slot2Download.onclick = () => downloadSavezoneSave(2);
        } else {
            slot2Date.textContent = t('noSave');
            slot2Download.style.display = 'none';
        }
    }
}

// Calculate challenges completed from save data (copied from challenges-explorer logic)
function calculateChallengesCompleted(data) {
    if (!data || typeof CHALLENGES_DB === 'undefined') return 0;
    
    let completedCount = 0;
    
    // Helper functions
    const countUniquePokemon = (d) => {
        let count = 0;
        for (let key in d) {
            if (d[key]?.caught > 0 && d[key]?.movepool) count++;
        }
        return count;
    };
    
    const countShinies = (d) => {
        let count = 0;
        for (let key in d) {
            if (d[key]?.shiny && d[key]?.caught > 0) count++;
        }
        return count;
    };
    
    const countStarSigns = (d) => {
        let count = 0;
        for (let key in d) {
            if ((d[key]?.starsign || d[key]?.starSign) && d[key]?.caught > 0) count++;
        }
        return count;
    };
    
    const countLevel100 = (d) => {
        let count = 0;
        for (let key in d) {
            if (d[key]?.level >= 100 && d[key]?.caught > 0) count++;
        }
        return count;
    };
    
    // Check each challenge
    CHALLENGES_DB.forEach(challenge => {
        let currentValue = 0;
        
        // Calculate value based on challenge type
        switch(challenge.id) {
            case 'unique_pokemon':
            case 'catch_em_all':
            case 'gotta_catch_em_all':
                currentValue = countUniquePokemon(data);
                break;
            case 'first_shiny':
            case 'more_shiny':
                currentValue = countShinies(data);
                break;
            case 'star_shines':
            case 'more_star_shines':
                currentValue = countStarSigns(data);
                break;
            case 'level_100':
                currentValue = countLevel100(data);
                break;
            case 'max_level':
                // Count max level pokemon (level 100 + max evolution)
                let maxLevelCount = 0;
                for (let key in data) {
                    if (data[key]?.level >= 100 && data[key]?.caught > 0) {
                        // Check if fully evolved (simplified check)
                        maxLevelCount++;
                    }
                }
                currentValue = maxLevelCount;
                break;
            case 'divisions':
                // Count by division (simplified)
                currentValue = countUniquePokemon(data) >= 200 ? 1 : 0;
                break;
            case 'mega_evolutions':
                let megaCount = 0;
                for (let key in data) {
                    if (key.startsWith('mega') && data[key]?.caught > 0 && data[key]?.shiny &&
                        hasMegaStoneInSave(key, data)) megaCount++;
                }
                currentValue = megaCount;
                break;
            default:
                // Default: check if it has specific check function or use basic count
                if (challenge.check && typeof challenge.check === 'function') {
                    try { currentValue = challenge.check(data); } catch(e) {}
                }
        }
        
        // Calculate completed tiers
        let completedTiers = 0;
        for (let i = 0; i < challenge.tiers.length; i++) {
            if (currentValue >= challenge.tiers[i]) {
                completedTiers++;
            } else {
                break;
            }
        }
        
        if (completedTiers > 0) {
            completedCount++;
        }
    });
    
    return completedCount;
}

// Upload save to slot
async function uploadSavezoneSave(slot) {
    const username = localStorage.getItem('lastTeamAuthor');
    if (!username) {
        alert(t('savezoneLoginRequired'));
        return;
    }
    
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        // Protection: vérifier la taille (max 10MB)
        if (file.size > 10 * 1024 * 1024) {
            alert(t('invalidSave'));
            return;
        }
        
        // Protection: vérifier le type (doit être JSON)
        if (!file.name.endsWith('.json') && file.type !== 'application/json') {
            alert(t('invalidSave'));
            return;
        }
        
        try {
            const saveData = await readFileAsJSON(file);
            
            // Protection: vérifier que c'est un objet
            if (!saveData || typeof saveData !== 'object') {
                alert(t('invalidSave'));
                return;
            }
            
            // Validate save data (doit avoir 'saved' avec version ou previewTeams)
            const hasSaved = saveData.saved && typeof saveData.saved === 'object';
            const hasVersion = hasSaved && (saveData.saved.version || saveData.saved.previewTeams);
            
            if (!hasSaved || !hasVersion) {
                alert(t('invalidSave'));
                return;
            }
            
            // SECURITY: Validate save data for malicious content
            const validation = validateSaveData(saveData);
            if (!validation.valid) {
                console.error('[Savezone] Security validation failed:', validation.error);
                alert(t('invalidSave') + ' (Security: ' + validation.error + ')');
                return;
            }
            
            // SECURITY: Sanitize tagList HTML in all Pokemon
            for (const key in saveData) {
                const value = saveData[key];
                if (typeof value === 'object' && value !== null && 
                    'caught' in value && 'movepool' in value && 
                    value.caught >= 1 && value.tagList) {
                    // Sanitize tag icons
                    value.tagList = value.tagList.map(tag => ({
                        name: String(tag.name || '').substring(0, 50),
                        color: String(tag.color || '').substring(0, 20),
                        icon: sanitizeHTML(tag.icon)
                    }));
                }
            }
            
            // Calculer les challenges directement depuis la save
            const challengesCount = calculateChallengesCompleted(saveData);
            
            const response = await fetch(`${SAVEZONE_API_URL}?action=savezone_upload&username=${encodeURIComponent(username)}&slot=${slot}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ saveData, challengesCount })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert(t('saveUploaded'));
                
                // Auto-import to Challenges/Succès if available
                importToChallenges(saveData);
                
                await loadSavezoneData();
            } else {
                alert(result.error || t('uploadFailed'));
            }
        } catch (err) {
            console.error('[Savezone] Upload error:', err);
            alert(t('uploadFailed'));
        }
    };
    
    input.click();
}

// Download save from slot
async function downloadSavezoneSave(slot) {
    const username = localStorage.getItem('lastTeamAuthor');
    if (!username) return;
    
    try {
        const response = await fetch(`${SAVEZONE_API_URL}?action=savezone_download&username=${encodeURIComponent(username)}&slot=${slot}`);
        const data = await response.json();
        
        if (data.success && data.saveData) {
            const blob = new Blob([JSON.stringify(data.saveData, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `pokechill_save_${username}_slot${slot}_${new Date().toISOString().split('T')[0]}.json`;
            a.click();
            URL.revokeObjectURL(url);
        } else {
            alert(t('noSaveFound'));
        }
    } catch (err) {
        console.error('[Savezone] Download error:', err);
        alert(t('downloadFailed'));
    }
}

// Load community stats
async function loadCommunityStats() {
    const statsLoading = document.getElementById('savezone-stats-loading');
    const statsGrid = document.getElementById('savezone-stats-grid');
    
    if (statsLoading) statsLoading.style.display = 'block';
    if (statsGrid) statsGrid.style.display = 'none';
    
    try {
        const response = await fetch(`${SAVEZONE_API_URL}?action=savezone_stats`);
        const data = await response.json();
        
        if (data.success) {
            // Update scrolling ticker
            document.getElementById('ticker-players').textContent = formatNumber(data.stats.totalPlayers);
            document.getElementById('ticker-players-2').textContent = formatNumber(data.stats.totalPlayers);
            document.getElementById('ticker-shinies').textContent = formatNumber(data.stats.totalShinies);
            document.getElementById('ticker-shinies-2').textContent = formatNumber(data.stats.totalShinies);
            document.getElementById('ticker-starshines').textContent = formatNumber(data.stats.totalStarShines);
            document.getElementById('ticker-starshines-2').textContent = formatNumber(data.stats.totalStarShines);
            document.getElementById('ticker-achievements').textContent = formatNumber(data.stats.totalAchievements);
            document.getElementById('ticker-achievements-2').textContent = formatNumber(data.stats.totalAchievements);
            document.getElementById('ticker-caught').textContent = formatNumber(data.stats.totalCaught);
            document.getElementById('ticker-caught-2').textContent = formatNumber(data.stats.totalCaught);
            const uniqueEl = document.getElementById('ticker-unique');
            const uniqueEl2 = document.getElementById('ticker-unique-2');
            if (uniqueEl) uniqueEl.textContent = formatNumber(data.stats.totalUniquePokemon);
            if (uniqueEl2) uniqueEl2.textContent = formatNumber(data.stats.totalUniquePokemon);
            document.getElementById('ticker-teams').textContent = formatNumber(data.stats.totalTeams);
            document.getElementById('ticker-teams-2').textContent = formatNumber(data.stats.totalTeams);
        }
    } catch (err) {
        console.error('[Savezone] Stats error:', err);
        ['ticker-players', 'ticker-players-2', 'ticker-shinies', 'ticker-shinies-2',
         'ticker-starshines', 'ticker-starshines-2', 'ticker-achievements', 'ticker-achievements-2',
         'ticker-caught', 'ticker-caught-2', 'ticker-unique', 'ticker-unique-2', 'ticker-teams', 'ticker-teams-2'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.textContent = '-';
        });
    } finally {
        if (statsLoading) statsLoading.style.display = 'none';
        if (statsGrid) statsGrid.style.display = 'grid';
    }
}

// Helper: Read file as JSON
function readFileAsJSON(file) {
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = (e) => {
            try {
                resolve(JSON.parse(e.target.result));
            } catch (err) {
                reject(err);
            }
        };
        reader.onerror = reject;
        reader.readAsText(file);
    });
}

// Helper: Format number with separators
function formatNumber(num) {
    if (num === undefined || num === null) return '-';
    return num.toLocaleString();
}

// Helper: convertit le nom d'un Pokémon méga en nom de méga-gemme
// Gère les cas spéciaux: Charizard X/Y, Mewtwo X/Y
function getMegaStoneName(megaPkmnName) {
    const baseName = megaPkmnName.replace('mega', '').toLowerCase();
    const match = baseName.match(/^(.+?)(x|y)$/);
    if (match) {
        return match[1] + 'ite' + match[2].toUpperCase();
    }
    return baseName + 'ite';
}

// Helper: vérifie si un Pokémon méga a une méga-gemme associée
function hasMegaStone(megaPkmnName) {
    const stoneName = getMegaStoneName(megaPkmnName);
    return items[stoneName]?.type === 'mega';
}

// Helper: vérifie si le joueur possède la méga-gemme pour un Pokémon méga
function hasMegaStoneInSave(megaPkmnName, data) {
    if (!data) return false;
    const stoneName = getMegaStoneName(megaPkmnName);
    return items[stoneName]?.type === 'mega' && data[stoneName]?.got > 0;
}

// Go to savezone tab
function goToSavezone() {
    document.getElementById('user-dropdown').style.display = 'none';
    
    switchTab('savezone');
    setTimeout(initSavezone, 50);
}

// Monitor for savezone visibility
setInterval(() => {
    const savezonePanel = document.getElementById('savezone-panel');
    const isLoggedIn = !!localStorage.getItem('lastTeamAuthor');
    
    if (savezonePanel && savezonePanel.classList.contains('active') && isLoggedIn) {
        const slot1Date = document.getElementById('savezone-slot1-date');
        if (slot1Date && slot1Date.textContent === '-') {
            initSavezone();
        }
    }
}, 100);

// ============ SYNC VERS SUCCÈS ============

// Import uploaded save to Challenges/Succès
function importToChallenges(saveData) {
    // Check if ChallengesExplorer is available
    if (typeof ChallengesExplorer === 'undefined') {
        console.log('[Savezone] ChallengesExplorer not available');
        return;
    }
    
    try {
        // Load the save data into challenges
        window.loadedChallengesData = saveData;
        
        // Update challenges display if functions exist
        if (typeof renderChallenges === 'function') {
            const progress = ChallengesExplorer.getProgress();
            renderChallenges(progress);
        }
        if (typeof updateChallengesSummary === 'function') {
            updateChallengesSummary();
        }
        if (typeof updateChallengesButtonCompleted === 'function') {
            updateChallengesButtonCompleted();
        }
        if (typeof updateImportButtonVisibility === 'function') {
            updateImportButtonVisibility();
        }
        
        console.log('[Savezone] Auto-imported to Challenges');
    } catch (err) {
        console.error('[Savezone] Failed to import to Challenges:', err);
    }
}

// ============ POKÉDEX PERSONNEL ============

// Toggle Pokédex visibility
function toggleSavezonePokedex() {
    const content = document.getElementById('savezone-pokedex-content');
    const toggle = document.getElementById('savezone-pokedex-toggle');
    
    if (content.style.display === 'none') {
        content.style.display = 'block';
        toggle.style.transform = 'rotate(0deg)';
    } else {
        content.style.display = 'none';
        toggle.style.transform = 'rotate(-90deg)';
    }
}

// XSS Sanitizer for HTML content (tags icons)
function sanitizeHTML(html) {
    if (!html || typeof html !== 'string') return '';
    
    // Only allow specific SVG tags and attributes
    const allowedTags = ['svg', 'path', 'polygon', 'circle', 'rect', 'line', 'polyline', 'g'];
    const allowedAttrs = ['viewBox', 'fill', 'stroke', 'stroke-width', 'stroke-linecap', 'stroke-linejoin', 
                         'd', 'points', 'cx', 'cy', 'r', 'x', 'y', 'width', 'height', 'xmlns'];
    
    // Create a temporary element to parse HTML
    const temp = document.createElement('div');
    temp.innerHTML = html;
    
    // Remove script tags and event handlers
    const scripts = temp.querySelectorAll('script, style, iframe, object, embed');
    scripts.forEach(el => el.remove());
    
    // Check all elements
    const allElements = temp.querySelectorAll('*');
    for (const el of allElements) {
        const tagName = el.tagName.toLowerCase();
        
        // Remove disallowed tags
        if (!allowedTags.includes(tagName)) {
            el.remove();
            continue;
        }
        
        // Remove disallowed attributes and event handlers
        for (const attr of Array.from(el.attributes)) {
            const attrName = attr.name.toLowerCase();
            if (!allowedAttrs.includes(attrName) || attrName.startsWith('on')) {
                el.removeAttribute(attr.name);
            }
        }
    }
    
    return temp.innerHTML;
}

// Safe check for uploaded save data (prevent attacks)
function validateSaveData(saveData) {
    if (!saveData || typeof saveData !== 'object') {
        return { valid: false, error: 'Invalid save data structure' };
    }
    
    // Check for required fields
    if (!saveData.saved || typeof saveData.saved !== 'object') {
        return { valid: false, error: 'Missing save metadata' };
    }
    
    // Check version
    const version = saveData.saved.version;
    if (!version || version < 1 || version > 100) {
        return { valid: false, error: 'Invalid save version' };
    }
    
    // Check for malicious patterns in string values
    const suspiciousPatterns = [
        /<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi,
        /javascript:/gi,
        /on\w+\s*=/gi,
        /eval\s*\(/gi,
        /Function\s*\(/gi,
        /setTimeout\s*\(/gi,
        /setInterval\s*\(/gi
    ];
    
    function checkObject(obj, path = '') {
        for (const [key, value] of Object.entries(obj)) {
            const currentPath = path ? `${path}.${key}` : key;
            
            // Check key name (prevent prototype pollution)
            if (key === '__proto__' || key === 'constructor' || key === 'prototype') {
                return { valid: false, error: `Invalid key name: ${currentPath}` };
            }
            
            if (typeof value === 'string') {
                // Check string length
                if (value.length > 10000) {
                    return { valid: false, error: `String too long at: ${currentPath}` };
                }
                
                // Check for suspicious patterns
                for (const pattern of suspiciousPatterns) {
                    if (pattern.test(value)) {
                        return { valid: false, error: `Suspicious content detected at: ${currentPath}` };
                    }
                }
            } else if (typeof value === 'number') {
                // Check for reasonable number ranges
                if (value > 999999999 || value < -999999999) {
                    return { valid: false, error: `Number out of range at: ${currentPath}` };
                }
            } else if (Array.isArray(value)) {
                // Check array length
                if (value.length > 10000) {
                    return { valid: false, error: `Array too long at: ${currentPath}` };
                }
                const result = checkObject(value, currentPath);
                if (!result.valid) return result;
            } else if (typeof value === 'object' && value !== null) {
                const result = checkObject(value, currentPath);
                if (!result.valid) return result;
            }
        }
        return { valid: true };
    }
    
    return checkObject(saveData);
}

// Extract all Pokémon from user's save (using full pokemon data, not just previewTeams)
function extractUserPokemon(saves) {
    const pokemonMap = new Map();
    
    // Get save data from slot1
    let saveData = null;
    if (saves && saves.slot1 && saves.slot1.data) {
        saveData = saves.slot1.data;
    }
    
    if (!saveData) {
        return pokemonMap;
    }
    
    // Look for all Pokémon entries (those with 'caught' >= 1 and 'movepool' properties)
    Object.entries(saveData).forEach(([key, value]) => {
        if (typeof value === 'object' && value !== null && 
            'caught' in value && 'movepool' in value && 
            value.caught >= 1) {
            
            const name = key;
            
            // Handle tagList with HTML icons (sanitize for security)
            let tagList = value.tagList || [];
            if (Array.isArray(tagList)) {
                tagList = tagList.map(tag => ({
                    name: String(tag.name || '').substring(0, 50),
                    color: String(tag.color || '').substring(0, 20),
                    icon: sanitizeHTML(tag.icon) // Sanitize HTML icons
                }));
            }
            
            const pokemonData = {
                name: name,
                caught: value.caught || 0,
                shiny: value.shiny || false,
                shinyDisabled: value.shinyDisabled || false,
                starSign: value.starsign || value.starSign || null,
                starsignList: value.starsignList || [],
                level: value.level || 0,
                nature: value.nature || null,
                ability: value.ability || null,
                hiddenAbility: value.hiddenAbility || null,
                hiddenAbilityUnlocked: value.hiddenAbilityUnlocked || false,
                moves: value.moves || {},
                movepool: value.movepool || [],
                movepoolMemory: value.movepoolMemory || [],
                ivs: value.ivs || { hp: 0, atk: 0, def: 0, satk: 0, sdef: 0, spe: 0 },
                exp: value.exp || 0,
                decorOwned: value.decorOwned || [],
                // NEW: Support for game features
                pokerus: value.pokerus === true,
                ribbons: value.ribbons || [],
                tagList: tagList,
                tagCaught: value.tagCaught || null,
                tagShiny: value.tagShiny || null,
                tagObtainedIn: value.tagObtainedIn || null,
                tagSignature: value.tagSignature || null,
                recordSpiraling: value.recordSpiraling || 0,
                dictionaryTagIvSum: value.dictionaryTagIvSum || 0,
                dictionaryTagBstSum: value.dictionaryTagBstSum || 0
            };
            
            pokemonMap.set(name, pokemonData);
        }
    });
    
    return pokemonMap;
}

// Render user's Pokédex with lazy loading and search
let savezonePokedexData = [];
let savezonePokedexFiltered = [];
let savezonePokedexPage = 0;
const POKEDEX_PAGE_SIZE = 36;

function renderSavezonePokedex(saves) {
    const grid = document.getElementById('savezone-pokedex-grid');
    const empty = document.getElementById('savezone-pokedex-empty');
    const count = document.getElementById('savezone-pokedex-count');
    const content = document.getElementById('savezone-pokedex-content');
    
    if (!grid || !empty) return;
    
    const pokemonMap = extractUserPokemon(saves);
    
    if (pokemonMap.size === 0) {
        grid.style.display = 'none';
        empty.style.display = 'block';
        document.getElementById('pokedex-load-more').style.display = 'none';
        updatePersonalStats(null);
        if (count) count.textContent = '0';
        return;
    }
    
    empty.style.display = 'none';
    grid.style.display = 'grid';
    if (count) count.textContent = pokemonMap.size;
    
    // Les Pokémon sont déjà triés par ordre Pokédex dans la save
    // On conserve l'ordre original sans tri
    savezonePokedexData = Array.from(pokemonMap.values());
    savezonePokedexFiltered = [...savezonePokedexData];
    savezonePokedexPage = 0;
    
    // Update personal stats
    updatePersonalStats(saves);
    
    // Initialize filter options
    initPokedexFilters();
    
    // Initial render (first page)
    renderPokedexPage();
    updateLoadMoreButton();
    
    // Setup lazy loading après le premier rendu
    setTimeout(setupPokedexLazyLoading, 100);
}

function renderPokedexPage() {
    const grid = document.getElementById('savezone-pokedex-grid');
    if (!grid) return;
    
    const start = savezonePokedexPage * POKEDEX_PAGE_SIZE;
    const end = Math.min(start + POKEDEX_PAGE_SIZE, savezonePokedexFiltered.length);
    const pageData = savezonePokedexFiltered.slice(start, end);
    
    // Check if we're in "missing shiny family" mode
    const evolutionFilter = document.getElementById('pokedex-filter-evolution')?.value || 'all';
    const isMissingShinyMode = evolutionFilter === 'missing-shiny';
    
    const html = pageData.map(p => {
        const spriteUrl = p.shiny ? spriteShiny(p.name) : sprite(p.name);
        const starStyle = p.starSign ? getStellarStyle(p.starSign) : '';
        const badges = [];
        if (p.shiny && !p.shinyDisabled) badges.push('✨');
        if (p.starSign) badges.push('⭐');
        if (p.caught > 1) badges.push(`${p.caught}x`);
        if (p.pokerus) badges.push('💉');
        if (p.hiddenAbilityUnlocked) badges.push('🔓');
        
        // Local favorite (site only)
        const isFav = isPokemonFavorite(p.name);
        
        // Game tags (first one only for space) - view only
        const gameTag = p.tagList && p.tagList[0];
        const gameTagHtml = gameTag ? `
            <span style="display:inline-flex;align-items:center;gap:2px;padding:2px 6px;background:${gameTag.color || 'var(--accent-purple)'};color:${getContrastTextColor(gameTag.color)};border-radius:8px;font-size:0.6rem;margin:1px">
                ${gameTag.name}
            </span>
        ` : '';
        
        // In missing-shiny mode, show the whole family
        const familyHtml = isMissingShinyMode ? renderFamilyMini(p) : '';
        
        return `
            <div class="pokedex-card" data-name="${p.name}" onclick="showPokemonDetail('${p.name}')" style="cursor:pointer;background:var(--bg-input);border-radius:8px;padding:8px;text-align:center;transition:transform 0.2s,box-shadow 0.2s;position:relative${isMissingShinyMode ? ';min-height:160px' : ''}" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                ${isFav ? '<span style="position:absolute;top:4px;right:4px;color:var(--accent-gold);font-size:0.9rem">⭐</span>' : ''}
                <img src="${spriteUrl}" style="width:64px;height:64px;image-rendering:pixelated;${starStyle}" onerror="this.src='${sprite(p.name)}'" loading="lazy">
                <div style="font-size:0.75rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${formatPokemonName(p.name)}</div>
                <div style="font-size:0.7rem">${badges.join(' ')}</div>
                ${gameTagHtml ? `<div style="margin-top:4px">${gameTagHtml}</div>` : ''}
                ${familyHtml}
            </div>
        `;
    }).join('');
    
    if (savezonePokedexPage === 0) {
        grid.innerHTML = html;
    } else {
        grid.innerHTML += html;
    }
}

// Render mini family view for missing-shiny filter
function renderFamilyMini(p) {
    const family = getEvolutionFamily(p.name);
    if (family.length <= 1) return '';
    
    // Sort by pokedex order
    const sortedFamily = family.sort((a, b) => {
        const pDataA = pokemons[a];
        const pDataB = pokemons[b];
        if (pDataA && pDataB && pDataA.num && pDataB.num) {
            return pDataA.num - pDataB.num;
        }
        return a.localeCompare(b);
    });
    
    const membersHtml = sortedFamily.map(memberName => {
        const member = savezonePokedexData.find(p => p.name === memberName);
        const isShiny = member && member.shiny;
        const spriteUrl = isShiny ? spriteShiny(memberName) : sprite(memberName);
        const border = isShiny ? '2px solid #ffd700' : '1px solid var(--border)';
        const opacity = member ? '1' : '0.3';
        
        return `
            <div style="position:relative;display:flex;flex-direction:column;align-items:center">
                <img src="${spriteUrl}" style="width:28px;height:28px;image-rendering:pixelated;border-radius:4px;border:${border};opacity:${opacity}" onerror="this.src='${sprite(memberName)}'" title="${formatPokemonName(memberName)}${isShiny ? ' ✨' : ''}" loading="lazy">
                ${isShiny ? '<span style="position:absolute;top:-4px;right:-4px;font-size:8px">✨</span>' : ''}
            </div>
        `;
    }).join('');
    
    return `
        <div style="display:flex;justify-content:center;gap:3px;margin-top:8px;padding-top:6px;border-top:1px solid var(--border);flex-wrap:wrap">
            ${membersHtml}
        </div>
    `;
}

// IntersectionObserver pour lazy loading performant
let pokedexObserver = null;

function setupPokedexLazyLoading() {
    // Nettoyer l'ancien observer
    if (pokedexObserver) {
        pokedexObserver.disconnect();
    }
    
    const sentinel = document.getElementById('pokedex-sentinel');
    if (!sentinel) return;
    
    pokedexObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                if ((savezonePokedexPage + 1) * POKEDEX_PAGE_SIZE < savezonePokedexFiltered.length) {
                    savezonePokedexPage++;
                    renderPokedexPage();
                    updateLoadMoreButton();
                }
            }
        });
    }, {
        root: document.getElementById('savezone-pokedex-content'),
        rootMargin: '100px',
        threshold: 0.1
    });
    
    pokedexObserver.observe(sentinel);
}

function updateLoadMoreButton() {
    const sentinel = document.getElementById('pokedex-sentinel');
    if (!sentinel) return;
    
    const hasMore = (savezonePokedexPage + 1) * POKEDEX_PAGE_SIZE < savezonePokedexFiltered.length;
    sentinel.style.display = hasMore ? 'block' : 'none';
    
    // Mettre à jour le texte du bouton
    const btn = document.getElementById('pokedex-load-more');
    if (btn) {
        btn.style.display = hasMore ? 'block' : 'none';
    }
}

function loadMorePokedex() {
    if ((savezonePokedexPage + 1) * POKEDEX_PAGE_SIZE < savezonePokedexFiltered.length) {
        savezonePokedexPage++;
        renderPokedexPage();
        updateLoadMoreButton();
    }
}

// Initialize filter options (types, abilities) - Match game exactly
function initPokedexFilters() {
    // Populate type filters
    const type1Select = document.getElementById('pokedex-filter-type');
    const type2Select = document.getElementById('pokedex-filter-type-2');
    
    if (type1Select && typeof TYPES !== 'undefined') {
        const typeOptions = TYPES.map(t => `<option value="${t}">${format(t)}</option>`).join('');
        type1Select.innerHTML = `<option value="all">${t('allTypes')}</option>${typeOptions}`;
        if (type2Select) type2Select.innerHTML = `<option value="all">${t('allTypes')}</option>${typeOptions}`;
    }
    
    // Populate ability filter - use rarity like in game
    const abilitySelect = document.getElementById('pokedex-filter-ability');
    if (abilitySelect) {
        abilitySelect.innerHTML = `
            <option value="all" data-i18n="filterAbility">${t('filterAbility')}</option>
            <option value="1" data-i18n="abilityCommon">${t('abilityCommon')}</option>
            <option value="2" data-i18n="abilityUncommon">${t('abilityUncommon')}</option>
            <option value="3" data-i18n="abilityRare">${t('abilityRare')}</option>
            <option value="4" data-i18n="abilityHALocked">${t('abilityHALocked')}</option>
        `;
    }
    
    // Populate shiny filter - match game options
    const shinySelect = document.getElementById('pokedex-filter-shiny');
    if (shinySelect) {
        shinySelect.innerHTML = `
            <option value="all" data-i18n="filterShiny">${t('filterShiny')}</option>
            <option value="true" data-i18n="shinyYes">${t('shinyYes')}</option>
            <option value="false" data-i18n="shinyNot">${t('shinyNot')}</option>
            <option value="sign" data-i18n="starShineMissing">${t('starShineMissing')}</option>
            <option value="signall" data-i18n="starShineAll">${t('starShineAll')}</option>
        `;
    }
    
    // Populate signature filter
    const sigSelect = document.getElementById('pokedex-filter-signature');
    if (sigSelect) {
        sigSelect.innerHTML = `
            <option value="all" data-i18n="filterSignature">${t('filterSignature')}</option>
            <option value="false" data-i18n="signatureOnly">${t('signatureOnly') || 'Has Signature'}</option>
            <option value="egg" data-i18n="eggMove">${t('eggMove')}</option>
        `;
    }
    
    // Populate ribbon filter
    const ribbonSelect = document.getElementById('pokedex-filter-ribbon');
    if (ribbonSelect) {
        ribbonSelect.innerHTML = `
            <option value="all" data-i18n="filterRibbon">${t('filterRibbon')}</option>
            <option value="any" data-i18n="ribbonAny">${t('ribbonAny')}</option>
            <option value="tower" data-i18n="ribbonTower">${t('ribbonTower')}</option>
            <option value="contest" data-i18n="ribbonSmile">${t('ribbonSmile')}</option>
            <option value="souvenir" data-i18n="ribbonSouvenir">${t('ribbonSouvenir')}</option>
        `;
    }
    
    // Populate evolution filter
    const evoSelect = document.getElementById('pokedex-filter-evolution');
    if (evoSelect) {
        evoSelect.innerHTML = `
            <option value="all" data-i18n="filterEvolution">${t('filterEvolution')}</option>
            <option value="missing" data-i18n="evolutionMissing">${t('evolutionMissing')}</option>
            <option value="level-only" data-i18n="evolutionLevelOnly">${t('evolutionLevelOnly')}</option>
            <option value="missing-shiny" data-i18n="evolutionMissingShiny">${t('evolutionMissingShiny')}</option>
        `;
    }
    
    // Populate pokerus filter
    const pokerusSelect = document.getElementById('pokedex-filter-pokerus');
    if (pokerusSelect) {
        pokerusSelect.innerHTML = `
            <option value="all" data-i18n="filterPokerus">${t('filterPokerus')}</option>
            <option value="true">💉 ${t('yes')}</option>
            <option value="false" data-i18n="no">${t('no')}</option>
        `;
    }
    
    // Populate tags filter - from game data only (view-only)
    populateTagsFilter();
    
    // Re-apply translations after populating filters
    if (typeof applyI18n === 'function') {
        applyI18n();
    }
}

// Populate tags filter with unique tags from user's Pokemon (game tags only, view-only)
function populateTagsFilter() {
    const tagsSelect = document.getElementById('pokedex-filter-tags');
    if (!tagsSelect) return;
    
    // Extract unique tag names from all Pokemon
    const uniqueTags = new Set();
    savezonePokedexData.forEach(p => {
        if (p.tagList && Array.isArray(p.tagList)) {
            p.tagList.forEach(tag => {
                if (tag.name) uniqueTags.add(tag.name);
            });
        }
    });
    
    const tagOptions = Array.from(uniqueTags).sort().map(tag => 
        `<option value="${escapeHtml(tag)}">${escapeHtml(tag)}</option>`
    ).join('');
    
    tagsSelect.innerHTML = `<option value="all">${t('filterTags') || '🏷️ Tags'}</option>${tagOptions}`;
}

// Escape HTML for safe display
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Calculate text color (black or white) based on background color for contrast
function getContrastTextColor(bgColor) {
    if (!bgColor || bgColor === 'var(--accent-purple)') return 'white';
    
    // Convert hex to RGB
    let r, g, b;
    if (bgColor.startsWith('#')) {
        const hex = bgColor.replace('#', '');
        if (hex.length === 3) {
            r = parseInt(hex[0] + hex[0], 16);
            g = parseInt(hex[1] + hex[1], 16);
            b = parseInt(hex[2] + hex[2], 16);
        } else {
            r = parseInt(hex.substring(0, 2), 16);
            g = parseInt(hex.substring(2, 4), 16);
            b = parseInt(hex.substring(4, 6), 16);
        }
    } else if (bgColor.startsWith('rgb')) {
        const match = bgColor.match(/\d+/g);
        if (match) {
            r = parseInt(match[0]);
            g = parseInt(match[1]);
            b = parseInt(match[2]);
        }
    } else {
        // Default to white for unknown colors
        return 'white';
    }
    
    // Calculate luminance (perceived brightness)
    const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
    
    // Return black for light backgrounds, white for dark backgrounds
    return luminance > 0.5 ? '#000000' : '#ffffff';
}

// Get Pokemon division from save data (same logic as game)
function getPokemonDivisionFromSave(pokemon) {
    if (!pokemon) return 'D';
    // Use pre-calculated value if available
    if (pokemon.dictionaryTagBstSum) {
        const bst = pokemon.dictionaryTagBstSum;
        if (bst >= 36) return 'SSS';
        if (bst >= 32) return 'SS';
        if (bst >= 28) return 'S';
        if (bst >= 24) return 'A';
        if (bst >= 20) return 'B';
        if (bst >= 16) return 'C';
    }
    // Fallback to pokemons data
    const pData = pokemons[pokemon.name];
    return pData?.division || 'D';
}

// Check if Pokemon has missing evolution (same logic as game)
// Uses evolutionRelations if available for complete family tree (Eevee, etc.)
function hasMissingEvolution(pokemon) {
    const pData = pokemons[pokemon.name];
    if (!pData) return false;
    
    // Use evolutionRelations if available (more complete)
    if (typeof evolutionRelations !== 'undefined') {
        const family = getCompleteEvolutionFamily(pokemon.name);
        for (const memberName of family) {
            if (memberName === pokemon.name) continue; // Skip self
            const member = savezonePokedexData.find(p => p.name === memberName);
            if (!member || member.caught === 0) return true;
        }
        return false;
    }
    
    // Fallback to direct evolutions only
    if (!pData.evolves || pData.evolves.length === 0) return false;
    
    // Check if any evolution is not caught
    for (const evoName of pData.evolves) {
        const evo = savezonePokedexData.find(p => p.name === evoName);
        if (!evo || evo.caught === 0) return true;
    }
    return false;
}

// Get complete evolution family - uses division.js getFullEvolutionChain if available
function getCompleteEvolutionFamily(pokemonName) {
    // Use the real function from division.js if it exists
    if (typeof getFullEvolutionChain === 'function') {
        const chain = getFullEvolutionChain(pokemonName);
        return chain.map(step => step.name);
    }
    
    // Fallback if evolutionRelations not available
    if (typeof evolutionRelations === 'undefined' || !evolutionRelations.evolvesTo) {
        return getEvolutionFamily(pokemonName);
    }
    
    // Manual implementation (same logic as division.js)
    const chain = [];
    const visited = new Set();
    
    // Find base (root) of the family
    let base = pokemonName;
    while (evolutionRelations.evolvesFrom[base]) {
        base = evolutionRelations.evolvesFrom[base];
    }
    
    // Recursive DFS to build chain
    const addToChain = (pkmnName) => {
        if (visited.has(pkmnName) || !pokemons[pkmnName]) return;
        visited.add(pkmnName);
        
        chain.push(pkmnName);
        
        const evos = evolutionRelations.evolvesTo[pkmnName] || [];
        evos.forEach(evo => addToChain(evo));
    };
    
    addToChain(base);
    return chain;
}

// Check if Pokemon evolves by level (has evolve function with level > 0)
function evolvesByLevel(pokemonName) {
    const pData = pokemons[pokemonName];
    if (!pData) return false;
    
    // Check if pokemon has evolve function with level-based evolution
    if (typeof pData.evolve === 'function') {
        try {
            const evoData = pData.evolve();
            if (evoData) {
                for (const key in evoData) {
                    if (evoData[key] && evoData[key].level > 0) {
                        return true;
                    }
                }
            }
        } catch(e) {
            return false;
        }
    }
    return false;
}

// Check if Pokemon has missing level evolution
function hasMissingLevelEvolution(pokemon) {
    const pData = pokemons[pokemon.name];
    if (!pData) return false;
    
    // Must evolve by level
    if (!evolvesByLevel(pokemon.name)) return false;
    
    // Check if any evolution is not caught and Pokemon is at max level
    if (pokemon.level < 100) return false;
    
    // Get family and check level-based evolutions
    const family = getCompleteEvolutionFamily(pokemon.name);
    for (const memberName of family) {
        if (memberName === pokemon.name) continue; // Skip self
        
        // Only check evolutions that evolve by level from this Pokemon
        const isDirectEvolution = typeof evolutionRelations !== 'undefined' && 
                                  evolutionRelations.evolvesFrom[memberName] === pokemon.name;
        if (!isDirectEvolution && pData.evolves && !pData.evolves.includes(memberName)) {
            continue; // Skip if not a direct evolution
        }
        
        const member = savezonePokedexData.find(p => p.name === memberName);
        if (!member || member.caught === 0) return true;
    }
    return false;
}

// Get complete evolution family (pre-evolutions + self + evolutions)
function getEvolutionFamily(pokemonName) {
    const family = new Set();
    const pData = pokemons[pokemonName];
    if (!pData) return [pokemonName];
    
    // Add self
    family.add(pokemonName);
    
    // Add direct evolutions
    if (pData.evolves && Array.isArray(pData.evolves)) {
        pData.evolves.forEach(evo => family.add(evo));
    }
    
    // Find pre-evolutions (Pokemon that evolve into this one)
    Object.entries(pokemons).forEach(([name, data]) => {
        if (data.evolves && data.evolves.includes(pokemonName)) {
            family.add(name);
            // Also add their pre-evolutions recursively
            Object.entries(pokemons).forEach(([preName, preData]) => {
                if (preData.evolves && preData.evolves.includes(name)) {
                    family.add(preName);
                }
            });
        }
    });
    
    // Add evolutions of evolutions (stage 2)
    const currentEvos = Array.from(family);
    currentEvos.forEach(name => {
        const data = pokemons[name];
        if (data && data.evolves && Array.isArray(data.evolves)) {
            data.evolves.forEach(evo => family.add(evo));
        }
    });
    
    return Array.from(family);
}

// Check if Pokemon has missing shiny in its evolution family
function hasMissingShinyInFamily(pokemon) {
    // Only check if this Pokemon is shiny
    if (!pokemon.shiny) return false;
    
    // Use complete family (handles Eevee's branched evolutions)
    const family = getCompleteEvolutionFamily(pokemon.name);
    
    // Check if all family members are shiny (only for available Pokemon)
    for (const memberName of family) {
        if (memberName === pokemon.name) continue; // Skip self
        
        // Skip if Pokemon doesn't exist in game data (unavailable forms)
        if (!pokemons[memberName]) continue;
        
        const member = savezonePokedexData.find(p => p.name === memberName);
        // If family member not caught or not shiny, we have a missing shiny
        if (!member || !member.shiny) return true;
    }
    return false;
}

// Render evolution family section for modal
function renderEvolutionFamily(p) {
    // Use complete family to handle branched evolutions (Eevee, etc.)
    const family = getCompleteEvolutionFamily(p.name);
    
    // Filter out unavailable Pokemon (not in pokemons data)
    const availableFamily = family.filter(name => pokemons[name]);
    
    if (availableFamily.length <= 1) return ''; // No family to show
    
    // Keep DFS order (don't sort by pokedex num to preserve branch structure)
    const familyHtml = availableFamily.map(memberName => {
        const member = savezonePokedexData.find(p => p.name === memberName);
        const isShiny = member && member.shiny;
        const isCaught = member && member.caught > 0;
        const spriteUrl = isShiny ? spriteShiny(memberName) : sprite(memberName);
        
        // Status indicator
        let statusIcon = '';
        let opacity = '1';
        if (!isCaught) {
            statusIcon = '❌'; // Not caught
            opacity = '0.4';
        } else if (isShiny) {
            statusIcon = '✨'; // Shiny
        } else {
            statusIcon = '⚪'; // Caught but not shiny
        }
        
        return `
            <div style="display:flex;flex-direction:column;align-items:center;gap:4px;opacity:${opacity}">
                <img src="${spriteUrl}" style="width:48px;height:48px;image-rendering:pixelated" onerror="this.src='${sprite(memberName)}'">
                <span style="font-size:0.65rem;text-align:center;max-width:60px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${formatPokemonName(memberName)}</span>
                <span style="font-size:0.8rem">${statusIcon}</span>
            </div>
        `;
    }).join('');
    
    return `
        <div style="background:var(--bg-input);padding:12px;border-radius:8px;margin-bottom:15px">
            <h4 style="margin:0 0 10px;color:var(--accent-gold);font-size:0.9rem">${t('evolutionFamily')}</h4>
            <div style="display:flex;justify-content:center;gap:15px;flex-wrap:wrap">
                ${familyHtml}
            </div>
            <div style="display:flex;justify-content:center;gap:10px;margin-top:8px;font-size:0.7rem;color:var(--text-dim)">
                <span>✨ ${t('shiny')}</span>
                <span>⚪ ${t('normal')}</span>
                <span>❌ ${t('notCaught')}</span>
            </div>
        </div>
    `;
}

// Favorite system - local only (separate from game tags)
function isPokemonFavorite(pokemonName) {
    const username = localStorage.getItem('lastTeamAuthor') || 'guest';
    const favoritesKey = `pokechill_pokedex_favorites_${username}`;
    const favorites = JSON.parse(localStorage.getItem(favoritesKey) || '[]');
    return favorites.includes(pokemonName);
}

function togglePokemonFavorite(pokemonName) {
    const username = localStorage.getItem('lastTeamAuthor') || 'guest';
    const favoritesKey = `pokechill_pokedex_favorites_${username}`;
    const favorites = JSON.parse(localStorage.getItem(favoritesKey) || '[]');
    
    const index = favorites.indexOf(pokemonName);
    if (index === -1) {
        favorites.push(pokemonName);
    } else {
        favorites.splice(index, 1);
    }
    
    localStorage.setItem(favoritesKey, JSON.stringify(favorites));
    
    // Refresh display
    const favBtn = document.getElementById('pokemon-fav-btn');
    if (favBtn) {
        const isFav = index === -1; // Was just added
        favBtn.innerHTML = isFav ? '⭐ ${t("favoriteRemove") || "Retirer"}' : '☆ ${t("favoriteAdd") || "Favori"}';
        favBtn.style.background = isFav ? 'linear-gradient(135deg,var(--accent-gold),var(--accent-orange))' : '';
    }
    
    // Refresh pokedex grid to update star icon
    renderPokedexPage();
}

// Check if Pokemon has Pokerus (from save data)
function hasPokerus(pokemon) {
    // Pokerus is stored in different ways depending on save version
    return pokemon.pokerus === true || pokemon.hasPokerus === true || 
           (typeof pokemon.tags === 'object' && pokemon.tags && pokemon.tags.includes('pokerus'));
}

// Filter/search Pokédex with advanced filters - Match game exactly
function filterPokedex() {
    const grid = document.getElementById('savezone-pokedex-grid');
    const empty = document.getElementById('savezone-pokedex-empty');
    const resultsCount = document.getElementById('pokedex-results-count');
    if (!grid) return;
    
    // Guard against empty/invalid data
    if (!Array.isArray(savezonePokedexData) || savezonePokedexData.length === 0) {
        grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:20px;color:var(--text-dim)">${t('noSaveFound') || 'No save data'}</div>`;
        if (resultsCount) resultsCount.textContent = '0 Pokémon';
        return;
    }
    
    // Get all filter values - match game IDs exactly
    const query = document.getElementById('pokedex-search')?.value?.toLowerCase().trim() || '';
    const type1 = document.getElementById('pokedex-filter-type')?.value || 'all';
    const type2 = document.getElementById('pokedex-filter-type-2')?.value || 'all';
    const levelValue = document.getElementById('pokedex-filter-level')?.value || 'all';
    const division = document.getElementById('pokedex-filter-division')?.value || 'all';
    const evolution = document.getElementById('pokedex-filter-evolution')?.value || 'all';
    const abilityRarity = document.getElementById('pokedex-filter-ability')?.value || 'all';
    const shinyFilter = document.getElementById('pokedex-filter-shiny')?.value || 'all';
    const signatureFilter = document.getElementById('pokedex-filter-signature')?.value || 'all';
    const ribbonFilter = document.getElementById('pokedex-filter-ribbon')?.value || 'all';
    const pokerusFilter = document.getElementById('pokedex-filter-pokerus')?.value || 'all';
    const tagsFilter = document.getElementById('pokedex-filter-tags')?.value || 'all';
    const favoriteOnly = document.getElementById('pokedex-filter-favorite')?.checked || false;
    const sortBy = document.getElementById('pokedex-filter-sort')?.value || '';
    
    // Apply filters - Match game logic exactly
    savezonePokedexFiltered = savezonePokedexData.filter(p => {
        // Guard clause - skip invalid entries
        if (!p || typeof p !== 'object') return false;
        if (!p.name || typeof p.name !== 'string') return false;
        
        const pData = (typeof pokemons !== 'undefined' && pokemons[p.name]) ? pokemons[p.name] : null;
        
        // Text search (search in name, moves, ability)
        if (query) {
            const inName = p.name && p.name.toLowerCase().includes(query);
            const inMoves = p.movepool && p.movepool.some(m => m && m.toLowerCase().includes(query));
            const inCurrentMoves = p.moves && Object.values(p.moves).some(m => m && m.toLowerCase().includes(query));
            const inAbility = p.ability && p.ability.toLowerCase().includes(query);
            if (!inName && !inMoves && !inCurrentMoves && !inAbility) return false;
        }
        
        // Type filters - match game logic
        if (type1 !== 'all' && pData) {
            if (!pData.types.includes(type1)) return false;
        }
        if (type2 !== 'all' && pData) {
            if (!pData.types.includes(type2)) return false;
        }
        
        // Level filter - match game logic (tiers of 20)
        if (levelValue !== 'all') {
            const levelNum = parseInt(levelValue);
            if (levelNum === 100) {
                if (p.level !== 100) return false;
            } else {
                // Game logic: level <= selected AND level >= selected-19
                if (!(p.level <= levelNum && p.level >= levelNum - 19)) return false;
            }
        }
        
        // Division filter - use calculated division from save
        if (division !== 'all') {
            if (getPokemonDivisionFromSave(p) !== division) return false;
        }
        
        // Ability rarity filter - match game logic
        if (abilityRarity !== 'all') {
            if (abilityRarity === '4') {
                // HA Locked: show Pokemon where HA is NOT unlocked AND has HA available
                const pData = pokemons[p.name];
                if (!pData || !pData.hiddenAbility) return false; // No HA available
                if (p.hiddenAbilityUnlocked) return false; // HA already unlocked
            } else {
                // Filter by ability rarity
                const abilityData = abilities[p.ability];
                if (!abilityData || abilityData.rarity != abilityRarity) return false;
            }
        }
        
        // Ribbon filter - 3 types: endurance (tower), smile, souvenir
        if (ribbonFilter !== 'all') {
            if (ribbonFilter === 'any') {
                // Has any ribbon
                if (!p.ribbons || p.ribbons.length === 0) return false;
            } else {
                // Specific ribbon type
                if (!p.ribbons || p.ribbons.length === 0) return false;
                const ribbonMap = {
                    'endurance': ['tower', 'endurance'],
                    'smile': ['smile'],
                    'souvenir': ['souvenir', 'event']
                };
                const keywords = ribbonMap[ribbonFilter] || [ribbonFilter];
                const hasRibbon = p.ribbons.some(r => {
                    if (!r) return false;
                    const rLower = r.toLowerCase();
                    return keywords.some(kw => rLower.includes(kw));
                });
                if (!hasRibbon) return false;
            }
        }
        
        // Signature/Egg Move filter - match game logic
        if (signatureFilter !== 'all') {
            if (signatureFilter === 'false' && !pData?.signature) return false;
            if (signatureFilter === 'egg' && !pData?.eggMove) return false;
        }
        
        // Shiny filter - match game logic exactly
        if (shinyFilter !== 'all') {
            if (shinyFilter === 'true' && !p.shiny) return false;
            if (shinyFilter === 'false' && p.shiny) return false;
            if (shinyFilter === 'sign') {
                // Star Sign missing: has at least one star sign but not all 6
                const starCount = p.starsignList ? p.starsignList.length : 0;
                // Must have at least 1 but less than 6
                if (starCount === 0 || starCount >= 6) return false;
            }
            if (shinyFilter === 'signall') {
                // All 6 star signs collected
                const starCount = p.starsignList ? p.starsignList.length : 0;
                if (starCount < 6) return false;
            }
        }
        
        // Pokerus filter
        if (pokerusFilter !== 'all') {
            const hasPokerus = p.pokerus === true;
            if (pokerusFilter === 'true' && !hasPokerus) return false;
            if (pokerusFilter === 'false' && hasPokerus) return false;
        }
        
        // Evolution filter
        if (evolution !== 'all') {
            if (evolution === 'missing' && !hasMissingEvolution(p)) return false;
            if (evolution === 'level-only' && !hasMissingLevelEvolution(p)) return false;
            if (evolution === 'missing-shiny' && !hasMissingShinyInFamily(p)) return false;
        }
        
        // Tags filter - filter by game tags (view-only)
        if (tagsFilter !== 'all') {
            const hasTag = p.tagList && p.tagList.some(tag => tag.name === tagsFilter);
            if (!hasTag) return false;
        }
        
        // Favorite only filter
        if (favoriteOnly) {
            if (!isPokemonFavorite(p.name)) return false;
        }
        
        return true;
    });
    
    // Apply sorting
    if (sortBy) {
        const [field, order] = sortBy.split('-');
        savezonePokedexFiltered.sort((a, b) => {
            let comparison = 0;
            
            switch (field) {
                case 'level':
                    comparison = a.level - b.level;
                    break;
                case 'name':
                    comparison = a.name.localeCompare(b.name);
                    break;
                case 'div':
                    const divOrder = { 'D': 1, 'C': 2, 'B': 3, 'A': 4, 'S': 5, 'SS': 6, 'SSS': 7 };
                    const divA = getPokemonDivisionFromSave(a);
                    const divB = getPokemonDivisionFromSave(b);
                    comparison = (divOrder[divA] || 0) - (divOrder[divB] || 0);
                    break;
            }
            
            return order === 'desc' ? -comparison : comparison;
        });
    }
    
    savezonePokedexPage = 0;
    
    // Update results count
    if (resultsCount) {
        resultsCount.textContent = `${savezonePokedexFiltered.length} Pokémon`;
    }
    
    if (savezonePokedexFiltered.length === 0) {
        grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:20px;color:var(--text-dim)">${t('noResults')}</div>`;
        const sentinel = document.getElementById('pokedex-sentinel');
        if (sentinel) sentinel.style.display = 'none';
    } else {
        renderPokedexPage();
        updateLoadMoreButton();
        setTimeout(setupPokedexLazyLoading, 100);
    }
}

// Clear all filters - match game behavior
function clearPokedexFilters() {
    const filters = ['type', 'type-2', 'level', 'division', 'evolution', 'ability', 'shiny', 'signature', 'ribbon', 'pokerus', 'tags'];
    filters.forEach(f => {
        const el = document.getElementById(`pokedex-filter-${f}`);
        if (el) el.value = 'all';
    });
    
    // Sort reset to empty
    const sortEl = document.getElementById('pokedex-filter-sort');
    if (sortEl) sortEl.value = '';
    
    // Reset favorite checkbox
    const favCheck = document.getElementById('pokedex-filter-favorite');
    if (favCheck) favCheck.checked = false;
    
    const search = document.getElementById('pokedex-search');
    if (search) search.value = '';
    
    filterPokedex();
}

function clearPokedexSearch() {
    clearPokedexFilters();
}

// Update personal stats display
function updatePersonalStats(saves) {
    if (!saves || !saves.slot1 || !saves.slot1.data) {
        document.getElementById('personal-caught').textContent = '0';
        document.getElementById('personal-unique').textContent = '0';
        document.getElementById('personal-shinies').textContent = '0';
        document.getElementById('personal-stars').textContent = '0';
        document.getElementById('personal-achievements').textContent = '0';
        document.getElementById('personal-teams').textContent = '0';
        return;
    }
    
    const data = saves.slot1.data;
    const stats = calculatePersonalStats(data);
    
    document.getElementById('personal-caught').textContent = formatNumber(stats.caught);
    document.getElementById('personal-unique').textContent = formatNumber(stats.uniquePokemon);
    document.getElementById('personal-shinies').textContent = formatNumber(stats.shinies);
    document.getElementById('personal-stars').textContent = formatNumber(stats.starShines);
    document.getElementById('personal-achievements').textContent = formatNumber(stats.achievements);
    document.getElementById('personal-teams').textContent = formatNumber(stats.teams);
}

function calculatePersonalStats(data) {
    const stats = {
        achievements: 0,
        caught: 0,
        shinies: 0,
        starShines: 0,
        uniquePokemon: 0,
        teams: 0
    };
    
    // Count achievements (calculated from save data)
    stats.achievements = calculateChallengesCompleted(data);
    
    // Count teams (only non-empty ones)
    if (data.saved && data.saved.previewTeams) {
        stats.teams = Object.values(data.saved.previewTeams).filter(team => {
            // Une équipe est non-vide si elle a au moins un slot avec un Pokémon
            return team && Object.values(team).some(slot => slot && slot.pkmn);
        }).length;
    }
    
    // Count Pokémon (only caught >= 1)
    Object.entries(data).forEach(([key, value]) => {
        if (typeof value === 'object' && value && 'caught' in value && 'movepool' in value && value.caught >= 1) {
            stats.caught += value.caught; // Total capturés (toutes espèces)
            stats.uniquePokemon++; // Uniques (nombre d'espèces)
            if (value.shiny) {
                stats.shinies++; // Compte TOUS les shinies (même désactivés), comme les challenges
            }
            if (value.starsign || value.starSign) {
                stats.starShines++; // Compte les star shines uniques
            }
        }
    });
    
    return stats;
}

// Show Pokémon detail modal
function showPokemonDetail(pokemonName) {
    const username = localStorage.getItem('lastTeamAuthor');
    if (!username) return;
    
    // Get user's save data
    const slot1 = document.getElementById('savezone-slot1-date');
    const hasSave = slot1 && slot1.textContent !== '-' && slot1.textContent !== t('noSave');
    
    if (!hasSave) {
        alert(t('noSaveFound'));
        return;
    }
    
    // Fetch save data to get full details
    fetch(`${SAVEZONE_API_URL}?action=savezone_download&username=${encodeURIComponent(username)}&slot=1`)
        .then(r => r.json())
        .then(data => {
            if (!data.success || !data.saveData) return;
            
            const pokemonMap = extractUserPokemon({ slot1: { data: data.saveData } });
            const pokemon = pokemonMap.get(pokemonName);
            
            if (!pokemon) return;
            
            createPokemonModal(pokemon);
        });
}

// Create Pokémon detail modal
function createPokemonModal(p) {
    const existing = document.getElementById('pokemon-detail-modal');
    if (existing) existing.remove();
    
    const spriteUrl = p.shiny ? spriteShiny(p.name) : sprite(p.name);
    const starStyle = p.starSign ? getStellarStyle(p.starSign) : '';
    
    // Format moves (moves is an object with slot1, slot2, etc.)
    const currentMoves = [];
    if (p.moves) {
        for (let i = 1; i <= 4; i++) {
            const moveKey = `slot${i}`;
            if (p.moves[moveKey]) {
                currentMoves.push(p.moves[moveKey]);
            }
        }
    }
    
    // Helper to get move type (try moves global, fallback to normal)
    function getMoveType(moveName) {
        if (typeof moves !== 'undefined' && moves[moveName]) {
            return moves[moveName].type || 'normal';
        }
        return 'normal';
    }
    
    const movesHtml = currentMoves.length > 0 
        ? currentMoves.map(m => {
            const type = getMoveType(m);
            return `<div style="display:flex;align-items:center;gap:5px">
                <span class="type-badge type-${type}" style="cursor:pointer" onclick="document.getElementById('pokemon-detail-modal').remove();showMovePokemon('${m}')">${format(m)}</span>
            </div>`;
        }).join('')
        : `<div style="color:var(--text-dim)">-</div>`;
    
    // Attaques apprises = movepool - les 4 actives
    const learnedMoves = (p.movepool || []).filter(m => !currentMoves.includes(m));
    const learnedMovesHtml = learnedMoves.length > 0 
        ? learnedMoves.map(m => {
            const type = getMoveType(m);
            return `<span class="type-badge type-${type}" style="font-size:0.7rem;cursor:pointer" onclick="document.getElementById('pokemon-detail-modal').remove();showMovePokemon('${m}')">${format(m)}</span>`;
        }).join(' ')
        : null;
    
    // Format relearnable moves (movepoolMemory = attaques récupérables avec Heart Scale)
    // Filter out moves already in learnedMoves OR currentMoves to avoid duplicates
    // Use lowercase comparison for robustness
    const uniqueRelearnMoves = (p.movepoolMemory || []).filter(m => {
        const mLower = m.toLowerCase();
        // Skip if already in learned moves (apprises) - case insensitive
        if (learnedMoves.some(lm => lm.toLowerCase() === mLower)) return false;
        // Skip if already in current moves (actives) - case insensitive
        if (currentMoves.some(cm => cm.toLowerCase() === mLower)) return false;
        return true;
    });
    const relearnHtml = uniqueRelearnMoves.length > 0 
        ? uniqueRelearnMoves.map(m => {
            const type = getMoveType(m);
            return `<span class="type-badge type-${type}" style="font-size:0.7rem;cursor:pointer" onclick="document.getElementById('pokemon-detail-modal').remove();showMovePokemon('${m}')">${format(m)}</span>`;
        }).join(' ')
        : `<span style="color:var(--text-dim)">-</span>`;
    
    // Format star signs list with real colors
    function getStarSignStyle(starSign) {
        if (typeof GAME_CONFIG !== 'undefined' && GAME_CONFIG.STAR_SIGNS && GAME_CONFIG.STAR_SIGNS[starSign]) {
            const hue = GAME_CONFIG.STAR_SIGNS[starSign].hue || 0;
            return `background:linear-gradient(135deg,hsl(${hue},70%,50%),hsl(${hue},70%,30%));color:#fff;`;
        }
        return 'background:linear-gradient(135deg,#ff6b9d,#c44569);color:#fff;';
    }
    
    const starSignsHtml = p.starsignList && p.starsignList.length > 0
        ? p.starsignList.map(s => `<span style="${getStarSignStyle(s)}padding:2px 8px;border-radius:10px;font-size:0.7rem;margin:2px">⭐ ${format(s)}</span>`).join('')
        : (p.starSign ? `<span style="${getStarSignStyle(p.starSign)}padding:2px 8px;border-radius:10px;font-size:0.7rem">⭐ ${format(p.starSign)}</span>` : '');
    
    // Get Pokemon tags from game data (tagList with HTML icons) - VIEW ONLY
    const gameTagsHtml = (p.tagList && p.tagList.length > 0)
        ? p.tagList.map(tag => `
            <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:${tag.color || 'var(--accent-purple)'};color:${getContrastTextColor(tag.color)};border-radius:12px;font-size:0.75rem">
                ${tag.icon ? `<span style="width:14px;height:14px;display:flex;align-items:center;justify-content:center">${tag.icon}</span>` : ''}
                ${tag.name}
            </span>`).join(' ')
        : '';
    
    // Local favorite status
    const isFav = isPokemonFavorite(p.name);
    
    // Check Pokerus
    const pokerusStatus = hasPokerus(p) 
        ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:#ff66aa;color:white;border-radius:12px;font-size:0.75rem">💉 Pokérus</span>`
        : '';
    
    // Ribbons HTML - 3 types: endurance, smile, souvenir
    // Tower/Endurance uses recordSpiraling value from save
    const ribbonsHtml = (p.ribbons && p.ribbons.length > 0)
        ? p.ribbons.map(r => {
            if (!r) return '';
            const rLower = r.toLowerCase();
            if (rLower.includes('endurance') || rLower.includes('tower')) {
                // Use recordSpiraling value from save data
                const record = p.recordSpiraling || 0;
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#ff4444,#cc0000);color:white;border-radius:12px;font-size:0.75rem">🏆 Endurance:${record}</span>`;
            } else if (rLower.includes('smile')) {
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#ff66aa,#cc4488);color:white;border-radius:12px;font-size:0.75rem">😊 Smile</span>`;
            } else if (rLower.includes('souvenir') || rLower.includes('event')) {
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#00d4ff,#0088cc);color:white;border-radius:12px;font-size:0.75rem">📸 Souvenir</span>`;
            }
            return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:var(--accent-purple);color:white;border-radius:12px;font-size:0.75rem">🏅 ${r}</span>`;
        }).join(' ')
        : '';
    
    // Format Hidden Ability - comme sur le reste du site
    // On récupère le nom de la HA depuis pokemons si dispo
    let haName = p.hiddenAbility;
    if (!haName && typeof pokemons !== 'undefined' && pokemons[p.name]) {
        haName = pokemons[p.name].hiddenAbility;
    }
    
    let haDisplay = null;
    if (haName) {
        const haLabel = typeof abilities !== 'undefined' && abilities[haName] 
            ? abilities[haName].displayName 
            : format(haName);
        if (p.hiddenAbilityUnlocked) {
            haDisplay = haLabel;
        } else {
            haDisplay = '🔒 ' + haLabel;
        }
    }
    // Si pas de HA dans les données du jeu, on affiche rien (pas de section)
    
    // === COPIE EXACTE DU CODE DE L'EXPORT GIF ===
    
    // === STRUCTURE DE LA SAVE ===
    // Les IVs sont stockés DIRECTEMENT comme nombre d'étoiles (0-6)
    // ivs: {"hp":6,"atk":6,"def":6,"satk":6,"sdef":6,"spe":6}
    // Les BST sont les valeurs brutes (20-110)
    // bst: {"hp":60,"atk":90,"def":55,"satk":90,"sdef":80,"spe":110}
    
    // Helper: Convertit BST (20-110) vers étoiles (1-6)
    function bstToRating(baseStat) {
        const r = 1 + (baseStat - 20) * (5 / 180);
        return Math.min(6, Math.max(1, Math.round(r)));
    }
    
    // Récupère les données
    const ivs = p.ivs || { hp: 0, atk: 0, def: 0, satk: 0, sdef: 0, spe: 0 };  // Déjà des étoiles 0-6
    const bst = (typeof pokemons !== 'undefined' && pokemons[p.name]) ? (pokemons[p.name].bst || {}) : {};
    
    // Nature adjustments (+1, -1, 0) - GAME_CONFIG.NATURES utilise les stats directes
    const natureAdjustments = { hp: 0, atk: 0, def: 0, satk: 0, sdef: 0, spe: 0 };
    if (p.nature && typeof GAME_CONFIG !== 'undefined' && GAME_CONFIG.NATURES && GAME_CONFIG.NATURES[p.nature]) {
        const n = GAME_CONFIG.NATURES[p.nature];
        // Les natures ont les stats directement: { spe: +1, def: -1, ... }
        if (n.hp) natureAdjustments.hp = n.hp > 0 ? 1 : -1;
        if (n.atk) natureAdjustments.atk = n.atk > 0 ? 1 : -1;
        if (n.def) natureAdjustments.def = n.def > 0 ? 1 : -1;
        if (n.satk) natureAdjustments.satk = n.satk > 0 ? 1 : -1;
        if (n.sdef) natureAdjustments.sdef = n.sdef > 0 ? 1 : -1;
        if (n.spe) natureAdjustments.spe = n.spe > 0 ? 1 : -1;
    }
    
    // Calculate real stats (formula: (bst_rating + nature) * 30 * 1.1^IV_stars)
    const realStats = {
        hp: Math.round((bstToRating(bst.hp || 0) + natureAdjustments.hp) * 30 * Math.pow(1.1, ivs.hp)),
        atk: Math.round((bstToRating(bst.atk || 0) + natureAdjustments.atk) * 30 * Math.pow(1.1, ivs.atk)),
        def: Math.round((bstToRating(bst.def || 0) + natureAdjustments.def) * 30 * Math.pow(1.1, ivs.def)),
        satk: Math.round((bstToRating(bst.satk || 0) + natureAdjustments.satk) * 30 * Math.pow(1.1, ivs.satk)),
        sdef: Math.round((bstToRating(bst.sdef || 0) + natureAdjustments.sdef) * 30 * Math.pow(1.1, ivs.sdef)),
        spe: Math.round((bstToRating(bst.spe || 0) + natureAdjustments.spe) * 30 * Math.pow(1.1, ivs.spe))
    };
    
    // Couleur selon nature - ACT (blanc pour neutre)
    const actColor = (stat) => {
        const adj = natureAdjustments[stat];
        if (adj > 0) return '#00ff88'; // Vert = boost
        if (adj < 0) return '#ff4444'; // Rouge = nerf
        return '#ffffff'; // Blanc = neutre
    };
    
    // Couleur selon nature - BST (bleu pour neutre)
    const bstColor = (stat) => {
        const adj = natureAdjustments[stat];
        if (adj > 0) return '#00ff88'; // Vert = boost
        if (adj < 0) return '#ff4444'; // Rouge = nerf
        return '#00d4ff'; // Bleu = neutre
    };
    
    // Helper: Get colored stars HTML for BST (exactement comme dans le GIF)
    function getBstColoredStarsHtml(baseStat, statKey) {
        const baseRating = bstToRating(baseStat);
        const adj = natureAdjustments[statKey] || 0;
        const final = Math.min(6, Math.max(1, baseRating + adj));
        
        let starsHtml = '';
        
        if (adj > 0) {
            // Boosted: base blue stars, then 1 green
            for (let i = 0; i < baseRating; i++) {
                starsHtml += '<span style="color:#00d4ff">★</span>';
            }
            starsHtml += '<span style="color:#00ff88">★</span>';
        } else if (adj < 0) {
            // Reduced: base-1 blue stars, then 1 red (if final > 0)
            const blueCount = Math.max(0, final - 1);
            for (let i = 0; i < blueCount; i++) {
                starsHtml += '<span style="color:#00d4ff">★</span>';
            }
            if (final > 0) {
                starsHtml += '<span style="color:#ff4444">★</span>';
            }
        } else {
            // Neutral: all blue stars
            for (let i = 0; i < final; i++) {
                starsHtml += '<span style="color:#00d4ff">★</span>';
            }
        }
        
        return starsHtml;
    }
    
    // ============ STATS SECTION - TABLE DESIGN ============
    
    const statLabels = ['HP', 'ATK', 'DEF', 'SPA', 'SPD', 'SPE'];
    const statKeys = ['hp', 'atk', 'def', 'satk', 'sdef', 'spe'];
    
    // Nature name
    let natureName = '';
    if (p.nature) {
        natureName = format(p.nature);
        if (typeof GAME_CONFIG !== 'undefined' && GAME_CONFIG.NATURES && GAME_CONFIG.NATURES[p.nature]) {
            const n = GAME_CONFIG.NATURES[p.nature];
            if (n.name) {
                const lang = window.currentLang || 'fr';
                natureName = n.name[lang] || n.name.fr || natureName;
            }
        }
    }
    
    const statsHtml = `
        <table style="width:100%;border-collapse:collapse;margin-bottom:20px;background:var(--bg-input);border-radius:12px;overflow:hidden">
            <!-- Header -->
            <thead>
                <tr>
                    <th style="padding:12px 8px;font-size:0.7rem;color:var(--text-dim);font-weight:600;width:45px"></th>
                    ${statLabels.map(label => `
                        <th style="padding:12px 4px;font-size:0.7rem;color:var(--text-dim);font-weight:600;text-align:center">${label}</th>
                    `).join('')}
                </tr>
            </thead>
            <tbody>
                <!-- ACT Row avec fond arrondi sur les stats uniquement -->
                <tr>
                    <td style="padding:10px 8px;font-size:0.75rem;color:#66ddff;font-weight:700;text-align:left">ACT</td>
                    ${statKeys.map((key, idx) => `
                        <td style="padding:10px 4px;text-align:center;background:rgba(102,204,255,0.1);${idx === 0 ? 'border-radius:8px 0 0 8px;' : idx === 5 ? 'border-radius:0 8px 8px 0;' : ''}">
                            <span style="font-weight:700;font-size:1.1rem;color:${actColor(key)}">${realStats[key] || 0}</span>
                        </td>
                    `).join('')}
                </tr>
                <!-- Nature Row (centered, plus visible) -->
                ${p.nature ? `
                <tr>
                    <td colspan="7" style="padding:10px;text-align:center">
                        <span style="font-size:0.85rem;color:#aaddbb;font-weight:600;background:rgba(100,200,150,0.15);padding:6px 16px;border-radius:12px">${natureName}</span>
                    </td>
                </tr>
                ` : ''}
                <!-- BST Row -->
                <tr>
                    <td style="padding:10px 8px;font-size:0.75rem;color:#6699ff;font-weight:700;text-align:left">BST</td>
                    ${statKeys.map(key => `
                        <td style="padding:10px 4px;text-align:center">
                            <div style="font-weight:600;font-size:0.95rem;color:${bstColor(key)};margin-bottom:2px">${bst[key] || 0}</div>
                            <div style="font-size:0.7rem;line-height:1">${getBstColoredStarsHtml(bst[key] || 0, key)}</div>
                        </td>
                    `).join('')}
                </tr>
                <!-- IV Row -->
                <tr>
                    <td style="padding:10px 8px;font-size:0.75rem;color:#ff5555;font-weight:700;text-align:left">IV</td>
                    ${statKeys.map(key => `
                        <td style="padding:10px 4px;text-align:center">
                            <span style="font-size:0.7rem;color:#ff5555">${'★'.repeat(ivs[key] || 0)}${'☆'.repeat(6 - (ivs[key] || 0))}</span>
                        </td>
                    `).join('')}
                </tr>
            </tbody>
        </table>
    `;
    
    const modal = document.createElement('div');
    modal.id = 'pokemon-detail-modal';
    modal.innerHTML = `
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.8);z-index:10000;display:flex;align-items:center;justify-content:center;padding:20px" onclick="if(event.target===this)this.remove()">
            <div style="background:var(--bg-card);border-radius:16px;max-width:500px;width:100%;max-height:90vh;overflow-y:auto;border:2px solid var(--accent-purple)" onclick="event.stopPropagation()">
                <div style="padding:20px">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                        <h3 style="margin:0;color:var(--accent-purple)">${t('savezonePokemonDetail')}</h3>
                        <button onclick="document.getElementById('pokemon-detail-modal').remove()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-dim)">×</button>
                    </div>
                    
                    <div style="text-align:center;margin-bottom:25px">
                        <img src="${spriteUrl}" style="width:120px;height:120px;image-rendering:pixelated;${starStyle}" onerror="this.src='${sprite(p.name)}'">
                        <h2 style="margin:15px 0 10px;font-size:1.5rem">${formatPokemonName(p.name)}</h2>
                        <div style="display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:10px">
                            ${p.shiny ? '<span style="background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;padding:6px 16px;border-radius:20px;font-size:0.9rem;font-weight:600">✨ Shiny</span>' : ''}
                            <span style="background:var(--bg-input);color:var(--text);padding:6px 16px;border-radius:20px;font-size:0.9rem">Lv.${p.level}</span>
                            <span style="background:var(--bg-input);color:var(--text);padding:6px 16px;border-radius:20px;font-size:0.9rem">${p.caught}x capturé</span>
                        </div>
                        <div style="display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-top:10px">
                            ${starSignsHtml || ''}
                            ${pokerusStatus}
                            ${p.hiddenAbilityUnlocked ? `<span style="padding:4px 10px;background:var(--accent-gold);color:#000;border-radius:12px;font-size:0.75rem">🔓 HA</span>` : ''}
                            ${ribbonsHtml}
                        </div>
                        ${gameTagsHtml ? `<div style="display:flex;justify-content:center;gap:5px;flex-wrap:wrap;margin-top:10px">${gameTagsHtml}</div>` : ''}
                    </div>
                    
                    ${statsHtml}
                    
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:20px">
                        <div style="background:var(--bg-input);padding:12px;border-radius:8px;cursor:pointer" onclick="${p.ability ? `document.getElementById('pokemon-detail-modal').remove();showAbilityPokemon('${p.ability}')` : ''}">
                            <div style="font-size:0.75rem;color:var(--text-dim);margin-bottom:4px">Talent</div>
                            <div style="font-weight:600">${p.ability ? format(p.ability) : '-'}</div>
                        </div>
                        ${haDisplay ? `
                        <div style="background:var(--bg-input);padding:12px;border-radius:8px;cursor:pointer" onclick="document.getElementById('pokemon-detail-modal').remove();showAbilityPokemon('${haName}')">
                            <div style="font-size:0.75rem;color:var(--text-dim);margin-bottom:4px">Hidden Ability</div>
                            <div style="font-weight:700;font-size:0.9rem;color:var(--accent-gold)">${haDisplay}</div>
                        </div>
                        ` : ''}
                    </div>
                    
                    <!-- 1. Movepool (4 attaques actives) -->
                    <div style="margin-bottom:15px">
                        <h4 style="margin:0 0 10px;color:var(--accent-blue)">Movepool (4 actives)</h4>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">${movesHtml}</div>
                    </div>
                    
                    <!-- 2. Attaques apprises (movepool - les 4 actives) -->
                    <div style="margin-bottom:15px">
                        <h4 style="margin:0 0 10px;color:var(--accent-cyan)">Attaques apprises (${learnedMovesHtml ? learnedMoves.length : 0})</h4>
                        <div style="display:flex;flex-wrap:wrap;gap:5px;max-height:150px;overflow-y:auto">${learnedMovesHtml || '<span style="color:var(--text-dim)">-</span>'}</div>
                    </div>
                    
                    <!-- 3. Attaques réapprenables (via Heart Scale, caché si vide ou doublons) -->
                    ${uniqueRelearnMoves.length > 0 ? `
                    <div style="margin-bottom:15px">
                        <h4 style="margin:0 0 10px;color:var(--accent-green)">Attaques réapprenables (${uniqueRelearnMoves.length})</h4>
                        <div style="display:flex;flex-wrap:wrap;gap:5px;max-height:200px;overflow-y:auto">${relearnHtml}</div>
                    </div>
                    ` : ''}
                    
                    <!-- Share & Favorite Buttons -->
                    <div style="display:flex;gap:10px;margin-top:20px;padding-top:20px;border-top:1px solid var(--border)">
                        <button onclick="generatePokemonShareCard(savezonePokedexData.find(p => p.name === '${p.name}'))" class="btn" style="flex:1;padding:12px;border-radius:10px;background:linear-gradient(135deg,var(--accent-gold),#ff8800);color:#000;font-weight:600">
                            📤 ${t('sharePokemon') || 'Partager'}
                        </button>
                        ${isFav ? `
                            <button onclick="togglePokemonFavorite('${p.name}');document.getElementById('pokemon-detail-modal').remove();showPokemonDetail('${p.name}')" class="btn btn-outline" style="padding:12px 20px;border-radius:10px;color:var(--accent-gold)">
                                ⭐
                            </button>
                        ` : `
                            <button onclick="togglePokemonFavorite('${p.name}');document.getElementById('pokemon-detail-modal').remove();showPokemonDetail('${p.name}')" class="btn btn-outline" style="padding:12px 20px;border-radius:10px">
                                ☆
                            </button>
                        `}
                    </div>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
}

// Helper: Format Pokémon name
function formatPokemonName(name) {
    return name.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

// Show clean Pokemon info modal (no user buttons)
function showPokemonInfo(pokemonName) {
    const p = savezonePokedexData.find(p => p.name === pokemonName);
    if (!p) return;
    
    const existing = document.getElementById('pokemon-info-modal');
    if (existing) existing.remove();
    
    const spriteUrl = p.shiny ? spriteShiny(p.name) : sprite(p.name);
    const starStyle = p.starSign ? getStellarStyle(p.starSign) : '';
    const pData = pokemons[p.name];
    
    // Format moves
    const currentMoves = [];
    if (p.moves) {
        for (let i = 1; i <= 4; i++) {
            const moveKey = `slot${i}`;
            if (p.moves[moveKey]) currentMoves.push(format(p.moves[moveKey]));
        }
    }
    
    // Star signs
    const starSignsHtml = p.starsignList && p.starsignList.length > 0
        ? p.starsignList.map(s => `<span style="background:linear-gradient(135deg,#ff6b9d,#c44569);color:#fff;padding:2px 8px;border-radius:10px;font-size:0.7rem;margin:2px">⭐ ${format(s)}</span>`).join('')
        : (p.starSign ? `<span style="background:linear-gradient(135deg,#ff6b9d,#c44569);color:#fff;padding:2px 8px;border-radius:10px;font-size:0.7rem">⭐ ${format(p.starSign)}</span>` : '');
    
    // Tags
    const gameTagsHtml = (p.tagList && p.tagList.length > 0)
        ? p.tagList.map(tag => `
            <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:${tag.color || 'var(--accent-purple)'};color:${getContrastTextColor(tag.color)};border-radius:12px;font-size:0.75rem">${tag.name}</span>`).join(' ')
        : '';
    
    // IVs
    const ivsHtml = Object.entries(p.ivs || {}).map(([stat, val]) => {
        const statLabels = { hp: 'PV', atk: 'Att', def: 'Def', satk: 'AttS', sdef: 'DefS', spe: 'Vit' };
        return `<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border)"><span>${statLabels[stat] || stat}</span><span style="color:${val >= 5 ? '#ffd700' : (val >= 3 ? '#aaa' : '#666')}">${'★'.repeat(val)}${'☆'.repeat(6-val)}</span></div>`;
    }).join('');
    
    const modal = document.createElement('div');
    modal.id = 'pokemon-info-modal';
    modal.innerHTML = `
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.85);z-index:10000;display:flex;align-items:center;justify-content:center;padding:20px" onclick="if(event.target===this)this.remove()">
            <div style="background:var(--bg-card);border-radius:16px;max-width:400px;width:100%;max-height:90vh;overflow-y:auto;border:2px solid var(--accent-blue)" onclick="event.stopPropagation()">
                <div style="padding:20px">
                    <div style="text-align:center;margin-bottom:20px">
                        <img src="${spriteUrl}" style="width:120px;height:120px;image-rendering:pixelated;${starStyle}" loading="lazy" onerror="this.src='${sprite(p.name)}'">
                        <h2 style="margin:10px 0 5px;font-size:1.4rem">${formatPokemonName(p.name)}</h2>
                        <div style="display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                            ${p.shiny ? '<span style="background:linear-gradient(135deg,#ffd700,#ffaa00);color:#000;padding:4px 12px;border-radius:15px;font-size:0.8rem;font-weight:600">✨ Shiny</span>' : ''}
                            <span style="background:var(--bg-input);padding:4px 12px;border-radius:15px;font-size:0.8rem">Lv.${p.level}</span>
                            ${pData?.division ? `<span style="background:var(--bg-input);padding:4px 12px;border-radius:15px;font-size:0.8rem">Div ${pData.division}</span>` : ''}
                        </div>
                        <div style="display:flex;justify-content:center;gap:5px;flex-wrap:wrap">
                            ${starSignsHtml}
                            ${hasPokerus(p) ? '<span style="background:#ff66aa;color:#fff;padding:2px 8px;border-radius:10px;font-size:0.7rem">💉 Pokérus</span>' : ''}
                            ${p.hiddenAbilityUnlocked ? '<span style="background:var(--accent-gold);color:#000;padding:2px 8px;border-radius:10px;font-size:0.7rem">🔓 HA</span>' : ''}
                        </div>
                        ${gameTagsHtml ? `<div style="margin-top:8px">${gameTagsHtml}</div>` : ''}
                    </div>
                    
                    <div style="background:var(--bg-input);padding:12px;border-radius:8px;margin-bottom:15px">
                        <div style="font-size:0.75rem;color:var(--text-dim);margin-bottom:4px">Talent</div>
                        <div style="font-weight:600">${p.ability ? format(p.ability) : '-'}</div>
                    </div>
                    
                    <div style="background:var(--bg-input);padding:12px;border-radius:8px;margin-bottom:15px">
                        <div style="font-size:0.8rem;color:var(--accent-blue);margin-bottom:8px;font-weight:600">Attaques</div>
                        ${currentMoves.length > 0 ? currentMoves.map(m => `<div style="padding:3px 0;font-size:0.9rem">• ${m}</div>`).join('') : '<div style="color:var(--text-dim)">-</div>'}
                    </div>
                    
                    <div style="background:var(--bg-input);padding:12px;border-radius:8px">
                        <div style="font-size:0.8rem;color:var(--accent-gold);margin-bottom:8px;font-weight:600">IVs</div>
                        ${ivsHtml}
                    </div>
                    
                    <button onclick="document.getElementById('pokemon-info-modal').remove()" class="btn" style="width:100%;margin-top:15px;padding:10px;border-radius:8px">Fermer</button>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
}

// Share Pokemon with all info
function sharePokemon(pokemonName) {
    const username = localStorage.getItem('lastTeamAuthor');
    if (!username) {
        alert(t('savezoneLoginRequired'));
        return;
    }
    
    // Fetch save data to get full details
    fetch(`${SAVEZONE_API_URL}?action=savezone_download&username=${encodeURIComponent(username)}&slot=1`)
        .then(r => r.json())
        .then(data => {
            if (!data.success || !data.saveData) return;
            
            const pokemonMap = extractUserPokemon({ slot1: { data: data.saveData } });
            const pokemon = pokemonMap.get(pokemonName);
            
            if (!pokemon) return;
            
            generatePokemonShareCard(pokemon);
        });
}

// Generate share card for a Pokemon - Creates a beautiful image
async function generatePokemonShareCard(p) {
    const canvas = await generatePokemonImage(p);
    
    // Show share modal with preview
    const modal = document.createElement('div');
    modal.id = 'pokemon-share-modal';
    modal.innerHTML = `
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.85);z-index:10001;display:flex;align-items:center;justify-content:center;padding:20px" onclick="if(event.target===this)this.remove()">
            <div style="background:var(--bg-card);border-radius:16px;max-width:500px;width:100%;max-height:90vh;overflow-y:auto;border:2px solid var(--accent-gold);box-shadow:0 0 50px rgba(255,215,0,0.3)" onclick="event.stopPropagation()">
                <div style="padding:25px">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
                        <h3 style="margin:0;color:var(--accent-gold);display:flex;align-items:center;gap:10px">
                            📤 ${t('sharePokemon') || 'Partager Pokémon'}
                        </h3>
                        <button onclick="document.getElementById('pokemon-share-modal').remove()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-dim)">×</button>
                    </div>
                    
                    <!-- Preview Image -->
                    <div style="background:var(--bg-input);border-radius:12px;padding:10px;margin-bottom:20px;text-align:center">
                        <img id="pokemon-share-preview" src="${canvas.toDataURL('image/png')}" style="max-width:100%;border-radius:8px">
                    </div>
                    
                    <!-- Share Options -->
                    <div style="display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:15px">
                        <button onclick="downloadPokemonImage(savezonePokedexData.find(p => p.name === '${p.name}'))" class="btn" style="padding:15px;border-radius:10px;background:linear-gradient(135deg,var(--accent-purple),var(--accent-pink));font-size:1rem">
                            🖼️ ${t('downloadImage') || 'Télécharger l\'image'}
                        </button>
                    </div>
                    
                    <div style="background:var(--bg-input);border-radius:8px;padding:12px;margin-bottom:15px">
                        <p style="margin:0;font-size:0.85rem;color:var(--text-dim);text-align:center">
                            ${t('shareImageHelp') || 'L\'image sera téléchargée. Vous pouvez ensuite la partager où vous voulez !'}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
}

// Download Pokemon image
async function downloadPokemonImage(p) {
    if (!p) return;
    
    const canvas = await generatePokemonImage(p);
    const link = document.createElement('a');
    link.download = `${p.name}_card.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
}

// Helper: Load image and convert to base64, optionally apply hue rotation
async function loadImageBase64(url, hueRotate = 0) {
    return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            
            // Apply hue rotation if needed
            if (hueRotate !== 0) {
                ctx.filter = `hue-rotate(${hueRotate}deg)`;
            }
            
            ctx.drawImage(img, 0, 0);
            try {
                resolve(canvas.toDataURL('image/png'));
            } catch(e) {
                resolve(url);
            }
        };
        img.onerror = () => resolve(url);
        img.src = url;
    });
}

// Get hue rotation for star sign
function getStarSignHue(starSign) {
    if (typeof GAME_CONFIG !== 'undefined' && GAME_CONFIG.STAR_SIGNS && GAME_CONFIG.STAR_SIGNS[starSign]) {
        return GAME_CONFIG.STAR_SIGNS[starSign].hue || 0;
    }
    return 0;
}

// Generate beautiful Pokemon card image - Uses html2canvas on the detail modal
async function generatePokemonImage(p) {
    // First, create the modal content HTML directly for capture
    // We'll render it off-screen to capture everything
    const captureContainer = document.createElement('div');
    captureContainer.id = 'pokemon-capture-container';
    captureContainer.style.cssText = `
        position: fixed;
        top: -9999px;
        left: -9999px;
        width: 500px;
        z-index: -1;
    `;
    document.body.appendChild(captureContainer);
    
    // Render the modal content into this container
    // Use data from p directly (which comes from savezonePokedexData)
    const pData = pokemons[p.name];
    
    // Build the card HTML using p data
    const shiny = p.shiny || false;
    const shinyDisabled = p.shinyDisabled || false;
    const level = p.level || 1;
    const caught = p.caught || 0;
    const ability = p.ability || (pData ? pData.abilities?.[0] : null);
    const moves = p.moves || {};
    const ivs = p.ivs || { hp: 0, atk: 0, def: 0, satk: 0, sdef: 0, spe: 0 };
    const nature = p.nature || null;
    const starsignList = p.starsignList || [];
    const starSign = p.starSign || null;
    const ribbons = p.ribbons || [];
    const recordSpiraling = p.recordSpiraling || 0;
    const hiddenAbilityUnlocked = p.hiddenAbilityUnlocked || false;
    const movepool = p.movepool || [];
    const movepoolMemory = p.movepoolMemory || [];
    
    // Preload sprite as base64 with star sign hue if applicable
    const isShiny = shiny && !shinyDisabled;
    const spriteUrl = isShiny ? spriteShiny(p.name) : sprite(p.name);
    const starHue = starSign ? getStarSignHue(starSign) : 0;
    const spriteBase64 = await loadImageBase64(spriteUrl, starHue);
    
    // Build card HTML matching the modal exactly
    captureContainer.innerHTML = buildPokemonCardHTML(p.name, pData, {
        shiny, shinyDisabled, level, caught, ability, moves, ivs, nature,
        starsignList, starSign, ribbons, recordSpiraling, hiddenAbilityUnlocked,
        movepool, movepoolMemory, spriteBase64
    });
    
    // Wait for images to load
    await new Promise(r => setTimeout(r, 500));
    const images = captureContainer.querySelectorAll('img');
    await Promise.all(Array.from(images).map(img => {
        if (img.complete && img.naturalWidth > 0) return Promise.resolve();
        return new Promise((resolve) => {
            img.onload = () => resolve();
            img.onerror = () => resolve();
            setTimeout(resolve, 500);
        });
    }));
    
    // Get the card element
    const cardElement = captureContainer.querySelector('.pokemon-card');
    
    // Capture the card
    const canvas = await html2canvas(cardElement, {
        backgroundColor: '#0a0a12',
        scale: 2,
        useCORS: true,
        allowTaint: true,
        logging: false,
        height: cardElement.scrollHeight
    });
    
    // Clean up
    captureContainer.remove();
    
    return canvas;
}

// Build Pokemon card HTML for capture (matches modal exactly)
function buildPokemonCardHTML(name, pData, data) {
    // Handle shiny and star shine forms
    const isShiny = data.shiny && !data.shinyDisabled;
    const spriteUrl = data.spriteBase64 || (isShiny ? spriteShiny(name) : sprite(name));
    // Star hue is already applied to the sprite image itself
    const starStyle = '';
    const starColors = {
        'sol': '#22c55e', 'luna': '#eab308', 'pluto': '#3b82f6',
        'ceres': '#a855f7', 'terra': '#22c55e', 'eris': '#ec4899'
    };
    
    // Stats calculation
    const ivs = data.ivs || {};
    const bst = pData?.bst || {};
    const natureAdjustments = { hp: 0, atk: 0, def: 0, satk: 0, sdef: 0, spe: 0 };
    if (data.nature && GAME_CONFIG?.NATURES?.[data.nature]) {
        const n = GAME_CONFIG.NATURES[data.nature];
        if (n.hp) natureAdjustments.hp = n.hp > 0 ? 1 : -1;
        if (n.atk) natureAdjustments.atk = n.atk > 0 ? 1 : -1;
        if (n.def) natureAdjustments.def = n.def > 0 ? 1 : -1;
        if (n.satk) natureAdjustments.satk = n.satk > 0 ? 1 : -1;
        if (n.sdef) natureAdjustments.sdef = n.sdef > 0 ? 1 : -1;
        if (n.spe) natureAdjustments.spe = n.spe > 0 ? 1 : -1;
    }
    
    function bstToRating(baseStat) {
        const r = 1 + (baseStat - 20) * (5 / 180);
        return Math.min(6, Math.max(1, Math.round(r)));
    }
    
    function getAct(baseStat, iv, nature) {
        const bstRating = bstToRating(baseStat);
        return Math.round((bstRating + nature) * 30 * Math.pow(1.1, iv));
    }
    
    const actValues = {
        hp: getAct(bst.hp || 0, ivs.hp || 0, natureAdjustments.hp),
        atk: getAct(bst.atk || 0, ivs.atk || 0, natureAdjustments.atk),
        def: getAct(bst.def || 0, ivs.def || 0, natureAdjustments.def),
        satk: getAct(bst.satk || 0, ivs.satk || 0, natureAdjustments.satk),
        sdef: getAct(bst.sdef || 0, ivs.sdef || 0, natureAdjustments.sdef),
        spe: getAct(bst.spe || 0, ivs.spe || 0, natureAdjustments.spe)
    };
    
    const statKeys = ['hp', 'atk', 'def', 'satk', 'sdef', 'spe'];
    const statLabels = { hp: 'HP', atk: 'ATK', def: 'DEF', satk: 'SPA', sdef: 'SPD', spe: 'SPE' };
    
    // Type colors for moves
    const typeColors = {
        normal: '#A8A878', fire: '#F08030', water: '#6890F0', electric: '#F8D030',
        grass: '#78C850', ice: '#98D8D8', fighting: '#C03028', poison: '#A040A0',
        ground: '#E0C068', flying: '#A890F0', psychic: '#F85888', bug: '#A8B820',
        rock: '#B8A038', ghost: '#705898', dragon: '#7038F8', dark: '#705848',
        steel: '#B8B8D0', fairy: '#EE99AC'
    };
    function getMoveTypeColor(moveName) {
        const move = moves[moveName];
        return move ? (typeColors[move.type] || '#888') : '#888';
    }
    
    // Ribbons HTML
    const ribbonsHtml = (data.ribbons && data.ribbons.length > 0)
        ? data.ribbons.map(r => {
            if (!r) return '';
            const rLower = r.toLowerCase();
            if (rLower.includes('endurance') || rLower.includes('tower')) {
                const record = data.recordSpiraling || 0;
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#ff4444,#cc0000);color:white;border-radius:12px;font-size:0.75rem">🏆 Endurance:${record}</span>`;
            } else if (rLower.includes('smile')) {
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#ff66aa,#cc4488);color:white;border-radius:12px;font-size:0.75rem">😊 Smile</span>`;
            } else if (rLower.includes('souvenir')) {
                return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:linear-gradient(135deg,#00d4ff,#0088cc);color:white;border-radius:12px;font-size:0.75rem">📸 Souvenir</span>`;
            }
            return `<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:var(--accent-purple);color:white;border-radius:12px;font-size:0.75rem">🏅 ${r}</span>`;
        }).join(' ')
        : '';
    
    // Star signs HTML
    const starSignsHtml = (data.starsignList && data.starsignList.length > 0)
        ? data.starsignList.map(star => {
            const color = starColors[star.toLowerCase()] || '#888';
            return `<span style="display:inline-flex;align-items:center;gap:3px;padding:4px 10px;background:${color};color:white;border-radius:12px;font-size:0.7rem">⭐ ${format(star)}</span>`;
        }).join(' ')
        : '';
    
    // Moves HTML with type colors
    const currentMoves = [];
    for (let i = 1; i <= 4; i++) {
        if (data.moves[`slot${i}`]) currentMoves.push(data.moves[`slot${i}`]);
    }
    
    const movesHtml = currentMoves.map(m => {
        const bgColor = getMoveTypeColor(m);
        return `<span style="padding:6px 12px;background:${bgColor};color:#000;border-radius:6px;font-size:0.85rem;font-weight:500">${format(m)}</span>`;
    }).join(' ');
    
    // Learned moves with type colors
    const learnedMoves = data.movepool.filter(m => !currentMoves.includes(m));
    const learnedMovesHtml = learnedMoves.slice(0, 18).map(m => {
        const bgColor = getMoveTypeColor(m);
        return `<span style="padding:4px 10px;background:${bgColor};color:#000;border-radius:6px;font-size:0.75rem">${format(m)}</span>`;
    }).join(' ');
    
    // Relearnable moves with type colors
    const relearnMoves = data.movepoolMemory.filter(m => !currentMoves.includes(m) && !learnedMoves.includes(m));
    const relearnMovesHtml = relearnMoves.slice(0, 12).map(m => {
        const bgColor = getMoveTypeColor(m);
        return `<span style="padding:4px 10px;background:${bgColor};color:#000;border-radius:6px;font-size:0.75rem">${format(m)}</span>`;
    }).join(' ');
    
    // BST row with colored stars - smaller to fit
    const bstStarsHtml = statKeys.map(k => {
        const val = bst[k] || 0;
        const rating = bstToRating(val);
        const adj = natureAdjustments[k];
        const starColor = adj > 0 ? '#00ff88' : (adj < 0 ? '#ff4444' : '#00d4ff');
        return `<div style="text-align:center"><div style="color:${starColor};font-weight:600;font-size:0.9rem">${val}</div><div style="font-size:0.6rem;color:${starColor};white-space:nowrap;overflow:hidden">${'★'.repeat(rating)}</div></div>`;
    }).join('');
    
    // IV row - smaller stars to fit
    const ivStarsHtml = statKeys.map(k => {
        const val = ivs[k] || 0;
        return `<div style="text-align:center;font-size:0.6rem;color:#ff5555;white-space:nowrap;overflow:hidden">${'★'.repeat(val)}${'☆'.repeat(6-val)}</div>`;
    }).join('');
    
    return `
        <div class="pokemon-card" style="background:var(--bg-card);border-radius:16px;padding:20px;border:2px solid var(--accent-purple);font-family:Arial,sans-serif;color:var(--text);max-width:450px;">
            <h2 style="margin:0 0 15px 0;text-align:center;color:var(--text);font-size:1.8rem">${formatPokemonName(name)}</h2>
            
            <div style="text-align:center;margin-bottom:15px">
                <img src="${spriteUrl}" style="width:120px;height:120px;image-rendering:pixelated;${starStyle}" onerror="this.style.display='none'">
            </div>
            
            <div style="display:flex;justify-content:center;gap:10px;margin-bottom:15px;flex-wrap:wrap">
                ${isShiny ? '<span style="padding:6px 16px;background:#ffd700;color:#000;border-radius:20px;font-size:0.9rem;font-weight:600">✨ Shiny</span>' : ''}
                ${data.starSign ? `<span style="padding:6px 16px;background:linear-gradient(135deg,#ff6b9d,#c44569);color:#fff;border-radius:20px;font-size:0.9rem;font-weight:600">⭐ ${format(data.starSign)} Form</span>` : ''}
                <span style="padding:6px 16px;background:#1a1a2e;border:1px solid #2a2a4a;border-radius:20px;font-size:0.9rem">Lv.${data.level}</span>
                <span style="padding:6px 16px;background:#1a1a2e;border:1px solid #2a2a4a;border-radius:20px;font-size:0.9rem">${data.caught}x capturé</span>
            </div>
            
            ${starSignsHtml ? `<div style="display:flex;justify-content:center;gap:6px;margin-bottom:15px;flex-wrap:wrap">${starSignsHtml}</div>` : ''}
            
            ${ribbonsHtml || data.hiddenAbilityUnlocked ? `<div style="display:flex;justify-content:center;gap:6px;margin-bottom:15px;flex-wrap:wrap">
                ${data.hiddenAbilityUnlocked ? '<span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:#ffd700;color:#000;border-radius:12px;font-size:0.75rem">🔓 HA</span>' : ''}
                ${ribbonsHtml}
            </div>` : ''}
            
            <!-- Stats Table -->
            <div style="background:#1a1a2e;border-radius:12px;padding:15px;margin-bottom:15px">
                <!-- Stat Labels -->
                <div style="display:grid;grid-template-columns:50px repeat(6,1fr);gap:8px;text-align:center;margin-bottom:10px">
                    <span></span>
                    ${statKeys.map(k => `<span style="color:#8888aa;font-size:0.75rem">${statLabels[k]}</span>`).join('')}
                </div>
                <!-- ACT Row -->
                <div style="display:grid;grid-template-columns:50px repeat(6,1fr);gap:8px;text-align:center;margin-bottom:8px">
                    <span style="color:#66ddff;font-size:0.75rem;font-weight:600">ACT</span>
                    ${statKeys.map(k => {
                        const adj = natureAdjustments[k];
                        const color = adj > 0 ? '#00ff88' : (adj < 0 ? '#ff4444' : '#fff');
                        return `<span style="color:${color};font-weight:700;font-size:1.1rem">${actValues[k]}</span>`;
                    }).join('')}
                </div>
                <!-- Nature -->
                <div style="text-align:center;margin:10px 0">
                    <span style="background:#1a1a2e;border:1px solid #2a2a4a;padding:4px 16px;border-radius:12px;color:var(--text);font-size:0.85rem">${data.nature ? format(data.nature) : ''}</span>
                </div>
                <!-- BST Row -->
                <div style="display:grid;grid-template-columns:50px repeat(6,1fr);gap:8px;text-align:center;margin-bottom:8px">
                    <span style="color:#6699ff;font-size:0.75rem;font-weight:600">BST</span>
                    ${bstStarsHtml}
                </div>
                <!-- IV Row -->
                <div style="display:grid;grid-template-columns:50px repeat(6,1fr);gap:8px;text-align:center">
                    <span style="color:#ff5555;font-size:0.75rem;font-weight:600">IV</span>
                    ${ivStarsHtml}
                </div>
            </div>
            
            <!-- Ability -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:15px">
                <div style="background:#1a1a2e;border-radius:12px;padding:12px">
                    <div style="color:#8888aa;font-size:0.75rem;margin-bottom:4px">Talent</div>
                    <div style="font-weight:600;font-size:1.1rem">${data.ability ? format(data.ability) : '-'}</div>
                </div>
                <div style="background:#1a1a2e;border-radius:12px;padding:12px">
                    <div style="color:#8888aa;font-size:0.75rem;margin-bottom:4px">Hidden Ability</div>
                    <div style="font-weight:600;font-size:1.1rem;color:${data.hiddenAbilityUnlocked ? '#ffd700' : '#666'}">${pData?.hiddenAbility ? format(pData.hiddenAbility) : '-'}</div>
                </div>
            </div>
            
            <!-- Current Moves -->
            <div style="margin-bottom:15px">
                <div style="color:#00d4ff;font-weight:600;margin-bottom:8px">Movepool (4 actives)</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px">
                    ${movesHtml || '<span style="color:#666">-</span>'}
                </div>
            </div>
            
            <!-- Learned Moves -->
            ${learnedMoves.length > 0 ? `
            <div style="margin-bottom:15px">
                <div style="font-weight:600;margin-bottom:8px">Attaques apprises (${learnedMoves.length})</div>
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                    ${learnedMovesHtml}
                </div>
            </div>` : ''}
            
            <!-- Relearnable Moves -->
            ${relearnMoves.length > 0 ? `
            <div style="margin-bottom:15px">
                <div style="color:#00ff88;font-weight:600;margin-bottom:8px">Attaques réapprenables (${relearnMoves.length})</div>
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                    ${relearnMovesHtml}
                </div>
            </div>` : ''}
            
            <!-- Footer -->
            <div style="text-align:center;color:#666;font-size:0.75rem;margin-top:20px;border-top:1px solid #2a2a4a;padding-top:10px">
                Via PokeChill Explorer
            </div>
        </div>
    `;
}
